	moveq	#1,d0
	jra		1b
	
* what: blits data on bg plane, no horizontal shifting (erase)
* args:
* < A0: pristine background
* < A1: dest buffer
* < D0: X (rounded to smaller 8-multiple)
* < D1: Y
* < D2: width in bytes
* < D4: height

* trashes: D0-D1

blit_background:
	movem.l	d2-d6/a0-a5,-(a7)
	lea		_custom,a5
	* adjust offset X: X//8
	lsr.w	#3,d0
	lea		mulBG_NB_BYTES_PER_ROW_table(pc),a4
	add.w	d1,d1
	* add Y offset: Y*NB_BYTES_PER_ROW
	add.w	(a4,d1.w),d0
	* same offset for source and destination
	add.w	d0,a1
	add.w	d0,a0

    move.l  #0x09f00000,d3    | A->D copy, ascending mode	
	move.w	#BG_NB_BYTES_PER_ROW,d1		| blit modulo

    sub.w   d2,d1       | blit modulo
    lsl.w   #6,d4
    lsr.w   #1,d2		| blit width
    add.w   d2,d4       | blit height
	
    * always the same settings

    * now just wait for blitter ready to write all registers
	WAIT_BLIT
    
    * blitter registers set

	WRITE_BLITTER_REG_LONG	d3,bltcon0	| sets con0 and con1

	WRITE_BLITTER_REG_WORD	d1,bltamod	|A modulo
	WRITE_BLITTER_REG_WORD	d1,bltdmod	|D modulo
							
	WRITE_BLITTER_REG_LONG	a0,bltapt	|source graphic top left corner
	WRITE_BLITTER_REG_LONG	a1,bltdpt	|destination top (bottom) left corner
	WRITE_BLITTER_REG_SIZE	d4	|rectangle size, starts blit
	
	* all bitplanes but not the last one that we'll clear
	
	.rept	NB_PLAYFIELD_PLANES-2
	.if	BG_SCREEN_PLANE_SIZE>0x7FFF
	add.l	#BG_SCREEN_PLANE_SIZE,a0
	add.l	#BG_SCREEN_PLANE_SIZE,a1
	.else
	add.w	#BG_SCREEN_PLANE_SIZE,a0
	add.w	#BG_SCREEN_PLANE_SIZE,a1
	.endif
	WAIT_BLIT
	* other bitplanes
	WRITE_BLITTER_REG_LONG	a0,bltapt	|source graphic top left corner
	WRITE_BLITTER_REG_LONG	a1,bltdpt	|destination top (bottom) left corner
	WRITE_BLITTER_REG_SIZE	d4	|rectangle size, starts blit
	.endr
	
	* last bitplane: just clear: just add to dest
	.if	BG_SCREEN_PLANE_SIZE>0x7FFF
	add.l	#BG_SCREEN_PLANE_SIZE,a1
	.else
	add.w	#BG_SCREEN_PLANE_SIZE,a1
	.endif
	
	* reuse d1 for bltcon0
	moveq	#1,d1
	ror.l	#8,d1     | AKA move.l  #0x01000000,d1   | minterm useD & rect clear (0xA) 

   * now just wait for blitter ready to write all registers
	WAIT_BLIT
    
	WRITE_BLITTER_REG_LONG	d1,bltcon0	
	WRITE_BLITTER_REG_LONG	a1,bltdpt	|destination top left corner
	WRITE_BLITTER_REG_SIZE	d4	|rectangle size, starts blit
	movem.l	(a7)+,d2-d6/a0-a5
	rts



really_update_sprites:
	rts
	
	***********************
	* erase previous BOBs *
	***********************
	
	move.l	bob_previous_drawed_sprites(pc),a4
	lea		_custom,a5


	* clear previous positions
	lea	background_restore_buffer,a0
	move.l	playfield_drawed_screen_ptr(pc),a1
	move.w	#NB_TARGET_SPRITES-1,d7
	WAIT_BLIT
	WRITE_BLITTER_REG_WORD	#-1,bltalwm		| needed for blit_background
1:
	move.w	(a4),d0
	bmi.b	11f		| x=0: inactive
	move.w	(2,a4),d1
	cmp.w	#BG_NB_LINES,d1
	jcc		11f				| too low: discard
	and.w	#0xFFF0,d0		| align on 16 lower bound
	* clear area where the sprite was
	move.l	#-1,(a4)+			| ack deletion by setting -1 in X & Y
	move.w	(a4)+,d4			| height
	move.w	(a4)+,d2		| width
				
	bsr		blit_background
	dbf		d7,1b	
	bra.b	12f
11:
	addq	#PREVIOUS_SPRITE_SIZE,a4
	dbf		d7,1b
12:	


	*********************
	* draw current BOBs *
	*********************
	
	GET_MEMORY_START_IN_A6
	lea		(SPRITE_ADDRESS+SPRITE_BUFFER_SIZE-CURRENT_SPRITE_SIZE,a6),a0
	*lea		mockup+SPRITE_BUFFER_SIZE-CURRENT_SPRITE_SIZE,a0


    lea _custom,A5
	move.l	bob_previous_drawed_sprites(pc),a6
	*lea		shared_bob_table,a4
	
	moveq	#NB_TARGET_SPRITES-1,d7
1:
	jbsr	update_one_bob
	subq.w	#CURRENT_SPRITE_SIZE,a0
	dbf		d7,1b

	rts
	
