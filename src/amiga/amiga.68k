hw_sprite_ram_buffer:
	.skip	HW_SPRITE_BUFFER_SIZE*8	| 8 64-bit wide sprites + control words + align
	
background_restore_buffer:
	.skip	BG_NB_BYTES_PER_ROW*CORKSCREW_NB_SCREENS		| margin for corkscrew
	.skip	BG_SCREEN_SIZE
		
bobs_screen_buffer_1:
	.skip	BG_NB_BYTES_PER_ROW*CORKSCREW_NB_SCREENS		| margin for corkscrew
	.skip	BG_SCREEN_SIZE
	.skip	BG_NB_BYTES_PER_ROW*48		| margin to avoid sprite blit wrap when game scrolls up
	.ifne	OPT_ENABLE_DOUBLE_BUFFERING
bobs_screen_buffer_2:
	.skip	BG_NB_BYTES_PER_ROW*CORKSCREW_NB_SCREENS		| margin for corkscrew
	.skip	BG_SCREEN_SIZE
	.skip	BG_NB_BYTES_PER_ROW*48
	.endif

	.skip	8



		