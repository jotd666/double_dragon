	.section	.datachip


	
	.macro	DECL_BITPLANES	bpoff_start,nb_planes
	.set	bpoff,\bpoff_start
	.rept	\nb_planes
	dc.w  0xe0+bpoff,0
	dc.w  0xe2+bpoff,0
	.set	bpoff,bpoff+4
	.endr
	.endm
	
	.macro	DECL_COLORS	offset,nb_colors
	.set	colidx,\offset
	.rept	\nb_colors
	dc.w	color+(colidx*2),0
	.set	colidx,colidx+1
	.endr
	.endm

	.macro	DECL_SPRITES
	.set	sprite_start,sprpt+0
	.rept	16
	* 2 slots
	.word	sprite_start,0
	.set	sprite_start,sprite_start+2
    .endr
	.endm

	.macro	DECL_32_COLORS
	DECL_COLORS	0,32
	.endm

	.macro	DECL_ROW
	.word   0x01+(y_pos<<8),0xFFFE
	.word   cop2lc,0        | jump high
	.word   cop2lc+2,0      | jump low
	.word   copjmp2,0
	DECL_BITPLANES	0,NB_PLAYFIELD_PLANES	
	.set	y_pos,y_pos+1
	.endm
	
	
blank_sprite:
	.long	0,0
	
blank_sound:
	ds.l	4
	
debug_copperlist:
	dc.w	bplcon0,0x200
	dc.w	color
debug_color:
	dc.w	0
	dc.l	-2
	


	
	* main copperlist
game_copperlist:
	* all sprites have the same palette no need to specify odd or even
	
	* black color background plane
	* enable sprite colors now
	.word	0x0601,0xFFFE
	
		

	
game_sprites:
	DECL_SPRITES
game_sprites_end:

copperlist_colors:
	.ifeq	OPT_AGA_MODE
	DECL_32_COLORS
	.else
	.set	bpl_count,0
	.rept	NB_PLAYFIELD_PLANES+1		| one more bank for sprites
	.word	bplcon3,(bpl_count<<13)+(BORDERBLANK<<5)
	.set	bpl_count,bpl_count+1
	DECL_32_COLORS
	.endr
	.endif

screen_start:
	.word	0x01+(0x20<<8),0xFFFE
bobs_bitplanes:
	DECL_BITPLANES	0,NB_PLAYFIELD_PLANES

	.word	bplcon1
fine_x_scroll_value:
	.word	0
	* here was first_rows (before I disabled it)
	* mid-line wait & extra interrupt
	.word	0x8001,0xFFFE
pal_intreq_block_game:
	.word	 intreq,0x8014  | call level 1 interrupt in the middle of a frame, also flag so copper interrupt knows that we're going to call copper int
	* here was second_rows (before I disabled it)
	
	* wait just before weapon displays (unless disabled in which case palette change happens in the middle
	* which is perfect so the shield of the infamous "this weapon has no effect" message has the proper color
	* (the "try again" text doesn't have the proper color, but who cares?)
weapon_palette_wait:
	.word	0xF001,0xFFFE
osd_lower_palette_switch_address:
	* dynamic palette for weapons & lives on OSD
	.word	cop2lc,0
	.word	cop2lc+2,0
* write COPPER_NOP here to apply lower palette, copjmp2 to skip it
osd_lower_palette_switch:
	.word	copjmp2,0
	.word	bplcon3,(2<<13)+(BORDERBLANK<<5)	| bank 2: color 64
osd_lower_palette:
	* first, weapon, then rest of palette
	.set	offset,2
	.rept	15
	.word	color+offset,0
	.set	offset,offset+2
	.endr
after_osd_lower_palette:
	* here was third_rows (before I disabled it)

	
	* pal limit
	.if		NB_PLAYFIELD_PLANES>6
    .word  0xFFCF,0xFFFE       | PAL wait 128 colors needs FFCF, FFDF fails
	.else
    .word  0xFFDF,0xFFFE       | PAL wait
	.endif
	* extra wait for PAL (NTSC can't afford this)
	* here was fourth_rows (before I disabled it)



	
pal_wait:
	*.word	xxxx
	.word	 intreq,0x8004



     .long    -2					
	.ascii	"ENDCPLST"
	

	
	* aligning on 8 bytes so .align will work
	* in the next datachip sections
	.align	8
	
		.section .bsschip
		
mirror_buffer:
	.skip	MIRROR_BUFFER_SIZE
mirror_buffer_end:

