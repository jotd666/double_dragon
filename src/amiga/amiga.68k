		.text


	    
_user:
    * if D0 contains "WHDL"
    * A0 contains resload
        
    cmp.l   #0x05748444c,D0	| WHDL
    bne.b   .standard
	move.b	d1,_keyexit
    move.l a0,_resload

	move.l	a0,a2
	lea	(_tag,pc),a0
	jsr	(resload_Control,a2)
	
    bra		.no_forbid
.standard:
	
    * open dos library, graphics library
    move.l  0x4.W,a6
    lea dosname,a1
    moveq.l #0,d0
    jsr _LVOOpenLibrary(a6)
    move.l  d0,_dosbase

	lea	read_args_string(pc),a0
	lea	program_args(pc),a1
	move.l	#program_args_end-program_args,d0
	lsr.l	#2,d0		| number of longs
	

	bsr	get_args_BCPL

0:	
	lea		program_args,a0

	move.l	(A0)+,D0	| INVINCIBLE/S
	beq.b	1f
	or.l	#1,cheat_flags
	st.b	cheat_used
1:
	move.l	(A0)+,D0	| INFLIVES/S
	beq.b	2f
	or.l	#2,cheat_flags
	st.b	cheat_used
2:
	move.l	(A0)+,D0	| CHEATKEYS/S
	beq.b	2f
	* cheat isn't used as long as no cheat key is used
	or.l	#0x10,cheat_flags
2:



	lea		_custom,a5
	lea		debug_copperlist,a0
	move.l	a0,cop1lc(a5)

* no multitask
	
	move.l	4.W,A6
	* system-friendly PAL/NTSC detect
	cmp.b #50,0x212(a6)		| vblankfrequency
	jeq	0f
	* set NTSC
	move.l	#NTSC_MONITOR_ID,monitor
0:
	lea graphicsname,a1
    moveq.l #0,d0
    jsr _LVOOpenLibrary(a6)
    move.l  d0,_gfxbase
    move.l	d0,a6
	move.l	38(a6),old_syscoplist
	move.l	34(A6),old_actiview		| gb_ActiView

	sub.l	a1,a1
	jsr	_LVOLoadView(a6)
	jsr	_LVOWaitTOF(a6)
	jsr	_LVOWaitTOF(a6)
	
	*jbsr		load_highscores
    * check if "floppy" file is here
    move.l  _dosbase(pc),a6
    move.l   #floppy_file,d1
    move.l  #1005,d2   | MODE_OLDFILE
    jsr     _LVOOpen(a6)
    move.l  d0,d1
    beq.b   .no_floppy
    * "floppy" file found
    jsr     _LVOClose(a6)
    * wait 2 seconds for floppy drive to switch off
    move.l  #100,d1
    jsr     _LVODelay(a6)
.no_floppy:

* no multitask
	
    move.l  4,a6
    jsr _LVOForbid(a6)

    
	sub.l	A1,A1
	jsr	_LVOFindTask(a6)		| find ourselves
	move.l	D0,A0
	move.l	#-1,184(A0)	| pr_WindowPtr: no more system requesters (insert volume, write protected...)

.no_forbid:
	.ifne	OPT_ENABLE_LOGGING
	* protection for end of cpu log buffer
	lea		log_buffer_end,a0
	move.l	#0xCAFECAFE,d0
	.rept	4
	move.l	d0,(a0)+
	.endr
	.endif


	* dummy copperlist with no bitplanes enabled
	lea		_custom,a5
	lea		debug_copperlist,a0
	move.l	a0,cop1lc(a5)
	


	move.l	cheat_flags,d0
	jeq		1f
	btst	#0,d0
	sne		invincible_flag
	btst	#1,d0
	sne		infinite_lives_flag
	btst	#2,d0
	sne		infinite_time_flag
	btst	#3,d0
	sne		skip_first_loop_flag
	move.b	d0,d1
	and.b	#3,d1
	jeq		2f
	* cheat key disable highscore only if used
	st.b	cheat_used
2:


0:
1:	
	
	move.b	start_level+3,start_level_flag
	
	* default is 25Hz, game crawls at 50Hz unless on pistorm
	move.l	misc_options,d1
	btst	#0,d1
	seq		frameskip
	btst	#1,d1
	sne		skip_intro_flag
	btst	#2,d1
	sne		no_level_music_flag
	btst	#3,d1
	sne		service_mode_flag
	.ifne	OPT_CD32_VERSION
	* force the flag
	st		no_level_music_flag
	.endif


	move.l	cheat_flags,d0
	btst	#0,d0
	beq.b	0f
	st		cheat_used
0:
	btst	#1,d0
	beq.b	0f
	st		cheat_used
0:
	btst	#2,d0
	beq.b	0f
	st		cheat_used
0:
	move.l	cheat_flags,d0
	btst	#3,d0
	beq.b	0f
	st		cheat_used

0:
	* set dip switches
	* (some settings are not modifiable)
	move.b	#0x20,d0	| demo sounds on
	tst.b	service_mode_flag
	jeq		0f
	bset	#6,d0
0:
	not.b	d0
	move.b	d0,dip_switches_1

	lea		lives_table,a0
	move.b	start_lives+3,d1
	and.w	#3,d1
	move.b	(a0,d1.w),d0


	lea		difficulty_table,a0
	move.b	difficulty_level+3,d1
	and.w	#3,d1
	move.b	(a0,d1.w),d1
	lsl.b	#4,d1
	or.b	d1,d0
	not.b	d0
	move.b	d0,dip_switches_2
	
	jsr	 _detect_controller_types

	jra		demo_game

	.ifndef	RELEASE
display_text:
0:
	move.b	(a1)+,d1
	jmi		1f
	sub.b	#0x20,d1
	move.b	d1,(1,a0)
	move.b	d0,(a0)
	jbsr	osd_video_word_dirty
	addq	#1,a0
	jra		0b
1:
	rts

	
* < A1: address
* < D0: number
num2hexstring:
	movem.l	d0-a6,-(a7)
	moveq	#3,d4		| nb digits
	move.l	#0xF000,D3
	moveq.l	#4,D2
	move.b	#'X',(A1)+	
.loop:
	move.w	D0,D1
	and.w	D3,D1
	rol.w	D2,D1
	cmp.b	#9,D1
	bgt	.letter
	add.b	#'0',D1
	move.b	D1,(A1)+
	bra	.loopend
.letter:
	add.b	#'A'-10,D1
	move.b	D1,(A1)+
.loopend:
	addq.l	#4,D2
	lsr.l	#4,D3
	dbf	D4,.loop
	st.b	(a1)
	movem.l	(a7)+,d0-a6
	rts
	
* < A0: address
* < D0: color
* < D1: value 16 bit
display_number:
	lea		(-8,a7),a7
	move.l	a7,a1
	exg	d0,d1
	jbsr	num2hexstring
	exg	d0,d1
	jbsr	display_text
	lea		(8,a7),a7
	rts
	
	
	.endif
	
* so memory is quadword-aligned (not trusting .align directives)
align_for_fmode:
	.ifne	OPT_AGA_MODE
	add.w	#0x8,a0
	move.l	a0,d0
	and.b	#0xF8,d0
	move.l	d0,a0
	.endif
	rts
	
* < D0: bcpl string (with leading size byte)
* < A1: dest C string
bcpl_arg_string_copy:
    movem.l D0-D2/A0-A1,-(a7)
	lsl.l	#2,d0
	moveq.l	#0,d2
    move.l  d0,a0
	move.b	(a0)+,d2	| size
	beq.b	1f
	subq	#1,d2
0:
	move.b	(a0)+,(a1)+
	dbf		d2,0b
1:
    movem.l (a7)+,D0-D2/A0-A1
    rts


bcpl_string_to_int:
    movem.l A0/A1,-(a7)
    lea temp_filename_buffer(pc),a1
    bsr bcpl_arg_string_copy
    * convert to integer
    move.l  a1,a0
    * < A0: pointer on C string
    * > D0: value
    * > D1: -1 if ok, position of the string if error
    bsr parse_integer
    movem.l  (a7)+,a0/a1
	rts
	
* parse integer from string
* < A0: pointer on C string
* > D0: value
* > D1: -1 if ok, position of the string if error
parse_integer:
    movem.l  d2/d3,-(a7)
    * go to end of string
    moveq.l #-1,d1
.loop1:
    addq.l  #1,d1
    tst.b   (a0,d1.w)
    bne.b   .loop1
    * d1 is the number of chars
    moveq.l #0,d0
    moveq.l #0,d2
    subq.l  #2,d1   | 10th power minus 1
.loop2:
    move.b  (a0)+,d2
    beq.b   .out
    
    cmp.b   #32,d2
    beq.b   .sk
    sub.b   #48,d2
    bcs.b   .error
    cmp.b   #10,d2
    bcc.b   .error
    move.w  d1,d3
    bmi.b   .doadd
.muloop:
    mulu    #10,d2
    dbf d3,.muloop
.doadd:
    add.l   d2,d0
.sk:
    subq.l  #1,d1
    bra.b   .loop2
.out:    
    movem.l  (a7)+,d2/d3
    rts
.error:
    moveq.l #0,d0
    bra.b   .error
	
    * thanks Toni for this 1.3 read argument code
BCPL_RdArgs = 78
	
	* a1 = pointer to result array. Must be LONG aligned!
	* a0 = formatting string. BSTR!
	* d0 = size of result array (number of LONGs)
get_args_BCPL:
	movem.l d2/d3/d4,-(sp)
	move.l d0,d3
	moveq #BCPL_RdArgs,d0
	move.l a0,d1
	lsr.l #2,d1
	move.l a1,d2
	lsr.l #2,d2
	moveq #0,d4
	bsr.s call_bcpl
	movem.l (sp)+,d2/d3/d4
	rts

	* d0 = gv index
	* d1-d4 = bcpl parms

BCPL_STACK = 3000

call_bcpl:
	movem.l d2-d7/a2-a6,-(sp)

	move.l d0,d6
	move.l d1,d5

	move.l 4.w,a6
	move.l	_dosbase(pc),a5


	sub.l a1,a1
	jsr	_LVOFindTask(a6)
	move.l d0,a4

	* allocate BCPL stack
	move.l #BCPL_STACK,d0
	move.l #65536+1,d1
	jsr	_LVOAllocMem(a6)
	move.l d0,d7
	beq.s 0f
	
	movem.l d7/a5/a6,-(sp)

	moveq #0,d0
	move.l d5,d1
	sub.l a0,a0
	move.l d7,a1
	lea 3*4(a1),a1
	move.l 136(a4),a2
	add.w	d6,d6
	add.w	d6,d6
	move.l 0(a2,d6.w),a4
	movem.l 46(a5),a5/a6
	jsr (a5) | call bcpl!
	
	movem.l (sp)+,d7/a5/a6

0:
	move.l d7,a1
	move.l #BCPL_STACK,d0
	jsr	_LVOFreeMem(a6)


	movem.l (sp)+,d2-d7/a2-a6
	rts




demo_game:
		move		#0x4000,_custom+intena						| disable interrupts
		move		#0x7FFF,_custom+intreq						| ack all interrupts
		bsr			platform_init					| amiga-specific init
		
0:	
	.ifne	OPT_ALIGNED_MEMORY
	* compute ram start for dev mode
	* align so real addresses LSW match actual arcade addresses
	* and lower 16-bit match original RAM & even ROM offsets (not for subcpu)
	*

	lea		dev_ram_buffer,a6
	move.l	a6,d0
	clr.w	d0
	move.l	d0,d1
	add.l	#0x10000+RAM_START,d1
	move.l	d1,ram_start_0000		| memory (0x0000-0x3FFF)
	move.l	d1,d0
	add.l	#0x10000,d0
	move.l	d0,sub_ram_start_0000	| sub-memory, right after (aligned on xxxx4yyyy but that's manageable!)
	
	* relocate rom tables just after shared RAM
	* for main cpu memory is contiguous (only 1 segment of memory RAM+ROM)
	* and 6809 memory access is way faster (except for banks)
	
	* copy the ROM data
	add.l	#ROM_START-RAM_START,d1
	move.l 	d1,a1
	move.w	#(0x10000-ROM_START)/4-1,d0
	.else
	* release mode

	* copy the ROM data after RAM
	lea		rom_buffer,a1
	move.w	#(0x10000-ROM_START)/4-1,d0
	.endif
	
	lea		rom_base,a0
0:
	move.l	(a0)+,(a1)+
	dbf		d0,0b

	* install bank 0 in 0x4000, we may as well use that space

	GET_MEMORY_START_AND_DP
	jbsr	install_bank_0
	
	* set dip switches
	* base settings, medium diff, 2 lives, demo sounds on
	st.b	(dsw_1_3804,a6)
	
	.ifndef	RELEASE
	* install dump and quit handler
	pea		dump_and_quit
	lea		2.W,a0
	move.l	#0x4AFC4EF9,(a0)+
	move.l	(a7)+,(a0)+
	.endif
	


	* enable interrupts. Game doesn't use them
	* but relies on vbl sync flags
	
	jbsr	cache_fg_tiles_address
	jbsr	cache_bg_tiles_address

*	lea		level_12_music,a0
*	move.l	a0,current_music_name
*	lea		module_buffer,a1
*	move.l	#BIGGEST_MUSIC_SIZE,d0
*	jbsr	load_file
	
	* load title context now, we'll need it
	move.w	#CTX_TITLE,d0
	jbsr	load_context
	
	* create mirror parts for common sprites
	* first initialize buffer address
	move.l	#mirror_buffer,mirror_buffer_ptr

	jbsr	mirror_common_sprites

	* init sub cpu. Original code then loops forever, we just return
	GET_SUB_MEMORY_POINTERS
	jbsr	sub_cpu_init
	jbsr	sub_boot_c009
	
	jbsr	cpu_init		| zero most registers
	moveq	#0,d5			| D5 too
	moveq	#0,d0
	jbsr	osd_set_bank
	GET_MEMORY_START_AND_DP	
	jmp		reset_8000								| pass control to the mpatrol core
	

mirror_common_sprites:
	rts
	
	*lea		shared_bob_table,a0
	move.w	#0x3FF,d7
0:
	move.l	(a0)+,d0
	jeq		100f
	* sprite here, get clut table
	move.l	d0,a1
	move.w	#SPRITE_NB_CLUTS-1,d6
1:
	move.l	(a1)+,d1
	jeq		2f
	* clut exists
	move.l	d1,a3
	lea		((NB_PLAYFIELD_PLANES+1)*4+8,a3),a2
	cmp.w	#-2,(a2)
	jeq		2f
	* we must generate mirrored data
	jbsr	compute_mirror_bitplanes
2:
	dbf		d6,1b
100:
	dbf		d7,0b
	* set top address as base for contextual mirror data
	move.l	mirror_buffer_ptr,mirror_buffer_context_ptr
	rts
	


	.ifndef	RELEASE
dump_and_quit:	
	jbsr	osd_dump_logs
	illegal
	.endif

*osd_black_colors:
*	lea		sprite_palette,a0
*	move.l	color_copper_pointers,a1	| tile entries 0-32
*	move.w	#TOTAL_NB_COLORS/2-1,d0
*1:
*	addq.w	#2,a1
*	clr.w	(a1)+
*	dbf		d0,1b
*2:
*	rts

osd_call_sub_irq:
	movem.l	d0-a6,-(a7)
	GET_SUB_MEMORY_POINTERS
	jbsr	sub_cpu_init
	jbsr	sub_irq_c02e
	movem.l	(a7)+,d0-a6
	rts

	
osd_colors_cycled:
* < A0: tile palette in RAM (but shadows hardware palette)
* format (RGB4) is: offset=$RG, offset+$40=$B0
* I imagine that on NeoGeo we just set the palette and so be it but here we have eliminated
* duplicate entries for tiles and were lucky enough on level 1 for instance to keep the exact unique
* colors for the tiles. So the RGB values used are the same as in the game, but the game uses 4 slots
* and we only have 3 slots. We'll have to adapt I doubt it will be noticeable
	OSD_ENTER
	movem.l	d0-a6,-(a7)
	GET_MEMORY_START_IN_A6

	movem.l	(a7)+,d0-a6
	OSD_EXIT
	rts

CTX_MENU = 0xE8997E8A
CTX_START_GAME = 0x8C9D5BF9

* called when palette is updated
* can use D1 & D2 as restored just afterwards
* < A6: memory
osd_palette_updated:
	lea		(fg_tiles_palette_1000,a6),a0
	moveq	#0,d1
	move.w	#0x180/4-1,d2		| "checksum" R,G of colors
0:
	add.l	(a0)+,d1
	dbf		d2,0b
	move.l	d1,0x200
	
	lea		context_lookup_table,a0
0:
	move.l	(a0)+,d2
	cmp.l 	#-1,d2
	jeq		0f
	cmp.l	d1,d2
	jeq		context_switch_found
	addq	#4,a0
	jra		0b
0:
	rts

context_switch_found:
	move.l	(a0)+,d2		| now d2 is the context
	movem.l	d0-a6,-(a7)
	move.l	d2,d0
	jbsr	load_context
	movem.l	(a7)+,d0-a6
	rts
	
	
* <D0=red,green,D1=blue
osd_set_flash_color:
	move.l	color_copper_pointers,a0
	addq	#2,a0
	tst.b	d0
	jeq		0f
	* yellow
	move.w	#0xFF0,(a0)
	rts
0:
	* back to black
	clr.w	(a0)
	rts
	
* very important for the amiga version as it allows to detect level/context switches
* and load the relevant parts (we can't have everything in memory)
* on 68k non-amiga versions (if done one day) derived on this port, this could be much simpler.
* I imagine that on NeoGeo we just set the palette and so be it.

osd_set_tile_palette:
	OSD_ENTER
	movem.l	d0-a6,-(a7)

	move.l	color_copper_pointers,a1	| entries 0-31
	move.w	#TOTAL_NB_COLORS/2,d0
	jbsr	load_palette

	movem.l	(a7)+,d0-a6
	OSD_EXIT
	rts

	
* < D0: context name
load_context:
	cmp.w	current_context,d0
	jne		0f
	* same context: don't load
	rts
0:
	movem.l	d0-a6,-(a7)
	jbsr	osd_disable_interrupts
	
	.ifne	OPT_ENABLE_LOGGING
	jbsr	purge_sprite_log_data
	jbsr	purge_tile_log_data
	.endif
	
	* clear mirror buffer (reset it just after the shared bob mirror data)
	move.l	mirror_buffer_context_ptr,mirror_buffer_ptr

	move.w	current_context,previous_context
	move.w	d0,current_context


1:
	lea	context_table,A0
	lsl.w	#4,d0		| 4 pointers
	lea 	(a0,d0.w),a2
	clr.l	context_sprite_table_ptr		| "free" sprites too
	
	* load foreground tiles
	lea		fg_character_table_buffer,a1
	move.l	#FG_TILE_FILE_MAX_SIZE,d0
	move.l	(a2)+,d1
	jeq		0f
	move.l	d1,a0
	jbsr	load_file
	
	lea		(NB_FG_COLORS*2,a1),a1			| skip palette
	move.l	a1,fg_tile_character_table
	
	move.l	a1,a0
	move.w	#NB_FG_PLANES,d5
	move.w	#FG_TILE_NB_CLUTS,d6
	move.w	#FG_TILE_COUNT,d7
	jbsr	relocate_tiles_file
	
*	lea		sprite_table_buffer,a1
*	move.l	a1,context_sprite_table_ptr
*	move.l	#SPRITE_FILE_MAX_SIZE,d0
*	jbsr	load_file
	
	* set fg palette (attached sprites)
	lea		fg_character_table_buffer,a0
	move.l	color_copper_pointers+TOTAL_NB_COLORS*4,a1	| entries 64-80
	move.w	#NB_FG_COLORS,d0
	jbsr	load_palette

0:	
	tst		current_context
	jne		0f
	jbsr	load_title_picture
0:
	* todo: copy the first level of pointers in fastmem (256*4: 1kb)
	jbsr	relocate_sprites_file

30:
	clr.l	bg_tile_character_table
	* load background tiles if any
	move.l	(a2)+,d0
	jeq		31f
	move.l	d0,a0
	lea		bg_character_table_buffer,a1
	move.l	a1,bg_character_table_buffer_ptr
	move.l	#BG_TILE_FILE_MAX_SIZE,d0
	jbsr	load_file
	
	lea		(NB_BG_COLORS*2,a1),a1			| skip palette
	move.l	a1,bg_tile_character_table
	
	move.l	a1,a0
	move.w	#NB_BG_PLANES,d5
	move.w	#BG_TILE_NB_CLUTS,d6
	move.w	#BG_TILE_COUNT,d7
	jbsr	relocate_tiles_file
	
	* set bg palette
	lea		bg_character_table_buffer,a0
	move.l	color_copper_pointers,a1	| entries 64-80
	move.w	#NB_BG_COLORS,d0
	jbsr	load_palette

31:

	
	* optimize: should we mirror Y tiles? only in some contexts
*	move.w	current_context,d0
*	lea		mirror_y_tile_table,a0
*	tst.b	(a0,d0.w)
*	sne		must_mirror_y_tiles
	
*	* if level 1 set (intro), pre-load level 12 music as may has been overwritten by highscore tune
*	tst.w	current_context
*	jne		0f
***	move.w	#LEVEL12_TUNE_SND*8,d0
*	jbsr	load_music_if_needed
*0:
*	* at start redraw everything
*	move.w	#START_X,game_scroll_x
*	move.w	#START_Y,game_scroll_y
*	move.w	game_scroll_x,previous_scroll_x
*	jbsr force_all_screen_redraw

	jbsr	osd_enable_interrupts

	movem.l	(a7)+,d0-a6
	rts
	
load_title_picture:
	* special case: load title pic & palette like it's bg tiles
	lea		sprite_table_buffer,a1
	lea		title_pic_filename,a0
	move.l	#SPRITE_FILE_MAX_SIZE,d0
	jbsr	load_file
	* just set the palette for now
	lea		sprite_table_buffer,a0
	move.l	color_copper_pointers,a1	| entries 0-xx
	move.w	(a0)+,d1				| nb bitplanes
	moveq	#1,d0
	lsl.w	d1,d0
	move.w	d0,d3
	* < A0 contains the palette
	jbsr	load_palette
	* also we need to relocate the bitmaps
	lea		sprite_table_buffer,a0
	move.w	(a0)+,d0		| nb bitplanes
	add.w	d3,a0
	add.w	d3,a0
	move.l	a0,d1
	* A0 is the base
	subq	#1,d0
	lea		(4,a0),a1	| skip dimensions
111:
	add.l	d1,(a1)+	| relocate
	dbf		d0,111b
0:
	rts
	
* < A0: start of bitmap (palette skipped)
* < D5: number of bitplanes on this layer (NB_FG_PLANES/NB_BG_PLANES)
* < D6: number of cluts on this layer (FG_TILE_NB_CLUTS/BG_TILE_NB_CLUTS)
* < D7: number of tiles on this layer (FG_TILE_COUNT/BG_TILE_COUNT)
relocate_tiles_file:
	movem.l	d0-a6,-(a7)
	* now relocate the tile file
	move.l	a0,bg_tile_character_table				| set character table pointer
	move.l	a0,d0
	subq	#1,d7
	subq	#1,d6
	subq	#1,D5
	move.w	d6,-(a7)
	move.w 	d5,-(a7)
0:
	move.l	(a0)+,d1
	jeq		10f
	add.l	d0,d1
	move.l 	d1,(-4,a0)
	move.l	d1,a1

	* relocate pointers on bitplane list in clut table
	move.w	2(a7),d6
1:
	move.l	(a1)+,d2
	jeq		5f
	add.l	d0,d2
	move.l	d2,(-4,a1)
	move.l	d2,a2
	* relocate pointers on bitplanes
	move.w	(a7),d5	| 5 bitplanes
2:
	move.l	(a2)+,d3
	jeq		4f
	add.l	d0,d3
	move.l	d3,(-4,a2)
4:
	dbf		D5,2b
5:
	dbf		d6,1b
10:
	dbf		d7,0b
	addq	#4,a7
	movem.l	(a7)+,d0-a6
	rts
	

relocate_sprites_file:
	* now relocate the tile file
	move.l	context_sprite_table_ptr,a0
	move.l	a0,d0
	jne		0f
	rts
0:
	moveq	#0,d7
0:
	move.l	(a0)+,d1
	jeq		10f
	add.l	d0,d1
	move.l 	d1,(-4,a0)
	move.l	d1,a1

	* relocate pointers on bitplane list in clut table
	moveq	#SPRITE_NB_CLUTS-1,d6
1:
	move.l	(a1)+,d2
	jeq		5f
	add.l	d0,d2
	move.l	d2,(-4,a1)
	move.l	d2,a2
	* relocate pointers on bitplanes
	move.l	a2,a3		| store bitplane data with headers for later
	addq	#8,a2		| skip dimensions (else boom!)
	moveq	#NB_PLAYFIELD_PLANES-1+1,D5  | mask!!
2:
	move.l	(a2)+,d3
	jeq		4f
	add.l	d0,d3
	move.l	d3,(-4,a2)
4:
	dbf		D5,2b
	* finished processing bitplanes. Do we have to compute mirror bitplanes?
	cmp.w	#-2,(a2)
	jeq		5f
	* yes, we need to fill the data
*	cmp.w	#0x91,d7
*	jne		55f
*	BREAKPOINT	"trunk"
*55:


	jbsr	compute_mirror_bitplanes
5:
	dbf		d6,1b
10:
	addq	#1,d7
	cmp.w	#SPRITE_COUNT,d7  
	jne		0b
	rts
	

* < A2: bitplane pointer list to fill
* < A3: original bitplane pointers (with headers)
	
compute_mirror_bitplanes:
	movem.l	d0-a6,-(a7)
	* mirror exists: must first copy the bitplane data above
	* a3 points on dimensions
	* compute memory needed to clone the bitmap
	move.l	mirror_buffer_ptr,a0
	move.w	(a3)+,d4		| height
	move.w	d4,d6 			| save height in d6
	move.w	(a3)+,d5		| width in bytes + 2
	addq	#4,a3			| skip rest to point on source bitplanes
	subq	#2,d5			| adjust to real data width
	mulu	d5,d4			| size of bitplane data
	addq	#2,d5		    | make up
	move.w	#NB_PLAYFIELD_PLANES-1+1,d3  | mask!!
	mulu	d4,d3			| size of data to allocate

	* first copy data so we can use in-place mirror routines (a bit wasteful but
	* not a big issue as this happens at level start)
	
	move.w	#NB_PLAYFIELD_PLANES-1+1,d3  | mask!!
100:
	move.l	(a3)+,d1
	jne		101f
	* null source bitmap
	clr.l	(a2)+
	jra		2f		| next bitplane
101:
	move.l	d1,a1		| get bitplane data
	move.l	a0,(a2)+		| store it
	move.w	d4,d0
	lsr.w	#1,d0
	subq	#1,d0
	* copy data
1:
	move.w	(a1)+,(a0)+
	dbf		d0,1b
	* check (too late) if the buffer overflowed. It will overflow on restore buffer so no risk of crashing
	* just detect it and stop
	.ifndef	RELEASE
	cmp.l	#mirror_buffer_end,a0
	jcs		0f
	BREAKPOINT	"mirror buffer too small"
	illegal
0:
	.endif
2:
	dbf		d3,100b
	move.l	a0,mirror_buffer_ptr	| update for next time
	* reset pointer, start mirroring
	lea		((-NB_PLAYFIELD_PLANES-1)*4,a2),a0
	move.w	#NB_PLAYFIELD_PLANES-1+1,d3  | mask!!
	lea		mirror_table,a1
	lea		mirror_function_table,a3
	.ifndef	MC68020
	move.w	d5,d0       | number of byte values (4: 16 bits + shifting)
	add.w	d0,d0
	move.l	(a3,d0.w),a3
	.else
	move.l	(a3,d5.w*2),a3		| compute mirror function once and for all
	.endif
0:
	move.w	d6,d1		| height
	subq	#1,d1		| minus one for dbf
	move.l	(a0)+,d0	| bitplane data
	jeq		1f
	move.l	d0,a2
	jsr		(a3)		| perform in-place mirror
1:
	dbf		d3,0b

	movem.l	(a7)+,d0-a6
	rts
	
* force screen redraw. Also wired on Ghosts'N'Goblins screen layout
* we'll use a conversion table
force_all_screen_redraw:
	lea		_custom,a5
	REALLY_WAIT_BLIT
	GET_MEMORY_START_IN_A6
	

	* force tile draw
	* retrieve tile values
	* this requires to convert the GnG address to DD address
	
	
	* given the current scroll X/Y, draw all tiles on screen
	move.w	game_scroll_x,d0
	move.w	d0,previous_scroll_x
	add.w	#START_HOST_SCROLL_X,d0			| give us some leeway to the left: 10 screens before havoc
	move.w	d0,host_scroll_x
	move.w	d0,min_scroll_x
	move.w	d0,d1
	add.w	#VISIBLE_SCROLL_WIDTH+BG_TILE_WIDTH,d1		| after that it triggers tile refresh
	move.w	d1,max_scroll_x
	
	move.w	host_scroll_x,d0
	
	move.w	d0,d5				| save scroll X
	lea		(bg_tiles_address_3000,a6),a5
	lea		gng2dd_table,a6
	move.w	game_scroll_x,d0
	lsr.w	#4,D0	| divide by 16 to get real X tile offset
	* now compute start address to fetch data from
	move.w	#0,d7
	* atm Y=0
	lsl.w	#5,d0	| times 32
	add.w	d0,d7	| start address

	move.w	d7,d6	| save current Y

	move.w	#0x10,d2	| size of screen in tiles
0:
	move.w	d6,d7	| set current Y row
	move.w	#COLUMN_SIZE-1,d1		|  (64 bit margin)
1:
	* compute X offset now align on 0x40
	move.w	d5,d0
	lsr.w	#8,d0
	lsr.w	#1,d0
	lsl.w	#6,d0
	move.w	d0,x_offset
	and.w	#0x3FF,d7		| wrap on memory
	* force tile draw

	movem.l	d1-d2/d5-d6,-(a7)
	move.w	(a6,d7.w*2),d6
	lea		(a5,d6.w),a0		| now DD address
	move.b	(a0)+,d1			| read tile code
	move.b	(a0),d0				| read tile color/attribute
	jbsr	update_bg_tile_gng	
	movem.l	(a7)+,d1-d2/d5-d6
	
	addq	#0x1,d7		| next X
	dbf		d1,1b
	add.w	#0x20,d6
	add.w	#BG_TILE_WIDTH,d5	| keep track of current "scroll"
	dbf		d2,0b
	clr.w	x_offset
	rts
	
	
draw_left_tiles:
	move.w	min_scroll_x,d0
	sub.w	#BG_TILE_WIDTH,d0		| else refresh will be okay but visible
	jra		draw_column_tiles
draw_right_tiles:
	move.w	max_scroll_x,d0

draw_column_tiles:
	* compute X offset
	move.w	d0,-(a7)
	lsr.w	#8,d0
	lsr.w	#1,d0
	lsl.w	#6,d0	
	move.w	d0,x_offset
	move.w	(a7)+,d0	
	GET_MEMORY_START_AND_DP

	lea		(bg_tiles_address_3000,a6),a5
	
	lea		gng2dd_table,a6
	lsr.w	#4,D0	| divide by 16 to get real X tile offset
	* now compute start address to fetch data from
	move.w	#0,d7		| first row is not visible with scroll=0, visible with=$10
	* atm Y=0
	lsl.w	#5,d0	| times 32
	add.w	d0,d7	| start address

	move.w	#COLUMN_SIZE-1,d2
0:
	and.w	#0x3FF,d7		| wrap
	* force tile draw
	* retrieve tile values
	* this requires to convert the GnG address to DD address
	
	move.w	(a6,d7.w*2),d6
	lea		(a5,d6.w),a0		| now DD address
	move.b	(a0)+,d1			| read tile code
	move.b	(a0),d0				| read tile color/attribute

	move.w	d2,-(a7)
	jbsr	update_bg_tile_gng
	move.w	(a7)+,d2
	
	addq	#1,d7			| next Y
	dbf		d2,0b
	rts

set_scroll_values:
	* update host scroll
	* handle 2 wrap points
	move.w	game_scroll_x,d0
	move.w	previous_scroll_x,d1
	move.w	d0,d2
	sub.w	d1,d2		| d2: diff between game scroll before / after
	
	cmp.w	#GAME_MAX_SCROLL_X-BG_TILE_WIDTH,d0
	jcs		0f
	* game scroll X >= 0x1F0
	cmp.w	#BG_TILE_WIDTH,d1
	jcc		0f
	* previous scroll X < 0x10: wrap left
	sub.w	#GAME_MAX_SCROLL_X,d2
	jra		1f
0:
	cmp.w	#BG_TILE_WIDTH,d0
	jcc		1f
	* game scroll X < 0x10
	cmp.w	#GAME_MAX_SCROLL_X-BG_TILE_WIDTH,d1
	jcs		1f
	* previous scroll X > 0x1F0: wrap right
	add.w	#GAME_MAX_SCROLL_X,d2
1:

0:
	* now let's check absolute value of scroll diff
	move.w	d2,d3
	jpl	2f
	neg.w	d3
2:
	cmp.w	#BG_TILE_WIDTH*2,d3
	jcs		3f
	* before/after diff is too big: redraw all
	* note that this screws the column updates if triggered
	* from somewhere else than a starting point. It could happen on
	* real hardware with BG_TILE_WIDTH value (screen "shake" because of high
	* object redraw time + erratic behaviour from the player :))
	jbsr	force_all_screen_redraw
	
	rts
3:
	move.w	d0,previous_scroll_x
	* update unwrapped host scroll X
	* we need it to be continuous!
	move.w	host_scroll_x,d0
	add.w	d2,d0
	move.w	d0,host_scroll_x
	
	* now, are we still in min/max boundaries?
	cmp.w	min_scroll_x,d0
	jcc		0f
	* min overshoot: we have to do something on the left

	jbsr	draw_left_tiles
	sub.w	#BG_TILE_WIDTH,max_scroll_x
	sub.w	#BG_TILE_WIDTH,min_scroll_x
	
	jra		5f
0:

	add.w	#VISIBLE_SCROLL_WIDTH,d0
	cmp.w	max_scroll_x,d0
	jcs		5f
	* max overshoot: we have to do something on the right: draw the tiles

	jbsr	draw_right_tiles
	add.w	#BG_TILE_WIDTH,max_scroll_x
	add.w	#BG_TILE_WIDTH,min_scroll_x

5:

	rts

	
	
* < A0: filename
* < A1: buffer
* < D0: max size
load_file:
	move.l	_resload,d1
	jeq		1f
	move.l	a2,-(a7)
	movem.l	d0-d2/a0-a1,-(a7)
	move.l	d1,a2
	move.l	d0,d2		| store max size
	jbsr	resload_GetFileSizeDec(a2)
	.ifndef	RELEASE
