BIT_PUNCH_1P = 1
BIT_PUNCH_2P = 2

	.include	"context.68k"
	
	.macro	COLOR0_FLASH	v
	.ifne	OPT_AGA_MODE
	move.w	#(BORDERBLANK<<5),_custom+bplcon3
	.endif
	move.w	#\v,_custom+color	
	.endm

	.macro	WRITE_TEXT	text,color
	
	lea		(fg_tile_address_table+0x47+0x20*row,a6),a0
	lea		\text,a1
	move.b	#\color,d0
	jbsr	display_text
	.set	row,row+1
	.endm

	.macro	WRITE_HEX	value,color
	move.w	\value,d1
	lea		(fg_tile_address_table+0x47+0x20*row+14,a6),a0
	move.b	#\color,d0
	jbsr	display_number
	.set	row,row+1
	.endm
	
	.macro	DO_BLIT
	WRITE_BLITTER_REG_SIZE  d4
	.ifndef	RELEASE
	*jbsr	log_blit
	.endif
	.endm
	
	* S aka D5 is used a lot in the code as virtual stack, not only
	* using host 68k SP. So we need to be consistent with its value
	* specially when the irq is called. Except that if the irq interrupts
	* an osd call, we need to restore the value of D5 on osd enter, not
	* the value within osd
	* OSD routines possibly using D5 or calling whdload / external libs MUST wrap their calls
	* with OSD_ENTER/OSD_EXIT.
	
	.macro	OSD_ENTER
	tst.b	osd_entry_count
	jne		osd_enter_\@

	* top entry: save game S register
	move.w	d5,target_ssp_value

osd_enter_\@:
	addq.b	#1,osd_entry_count	| increase nesting
	.endm
	
	.macro	OSD_EXIT
	subq.b	#1,osd_entry_count	| decrease nesting

	.endm
	
	

* exports

