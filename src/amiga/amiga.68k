SPRITE_Y_CORRECTION = -BG_TILE_WIDTH



* start displaying earlier in ntsc mode, allowing
* full display
NTSC_Y_SHIFT = 12

AGA_X_SHIFT = 0x37

FG_SCREEN_TILE_ADDRESS = 0x1800
BG_SCREEN_TILE_ADDRESS = 0x3000
SPRITE_ADDRESS = 0x2800
SPRITE_BUFFER_SIZE = 0x800

* if the alloc_sprite & update_sprite routines
* are reused, changing those offsets can make
* a quick reuse from game to game as most sprite
* RAMs have 4 bytes per sprite, only the order
* and some bits differ

TARGET_SPRITE_Y = 2
TARGET_SPRITE_X = 3
TARGET_SPRITE_ATTRIBUTES = 1
TARGET_SPRITE_CODE = 0
TARGET_SPRITE_SIZEOF = 4

MIRROR_BIT = 2
FLIT_BIT = 3


MAP_CONTEXT = 7

	.ifdef	RELEASE

OPT_ENABLE_LOGGING = 0           | DO NOT CHANGE THIS
OPT_DEBUG_BANKSWITCH = 0          | DO NOT CHANGE THIS
OPT_MIRROR_TEST = 0
	.else
OPT_ENABLE_LOGGING = 1
OPT_DEBUG_BANKSWITCH = 0
OPT_MIRROR_TEST = 0				| all sprites are mirrored
	.endif
	

OPT_ENABLE_DOUBLE_BUFFERING = 0

_custom = 0xDFF000

OPT_ENABLE_MULTIPLEXED_SPRITES = 0

	
	.if	NB_PLAYFIELD_PLANES>5
OPT_AGA_MODE=1
	.else
OPT_AGA_MODE=0
	.endif

* a plane of attached sprites	
NB_FG_PLANES = 4
NB_BG_PLANES = 5

NB_FG_COLORS = 1<<NB_FG_PLANES
NB_BG_COLORS = 1<<NB_BG_PLANES

TOTAL_NB_COLORS = 1<<NB_PLAYFIELD_PLANES
