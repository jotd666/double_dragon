*.byte  0xf8,0xf8,0xf8,0xf8,0xf8,0xf8,0xf8,0xf8,0xf8,0xf8,0xf8,0xf8,0xf8,0xf8,0xf8,0xf8	|	0x00e0
*.byte  0xf8,0xf8,0xf8,0xf8,0xf8,0xf8,0xf8,0xf8,0xf8,0xf8,0xf8,0xf8,0xf8,0xf8,0xf8,0xf8	|	0x00f0

compute_sprite_xy_code:
	moveq	#0,d0
	* attributes = buffered_spriteram[offs + 1]
	* sx = buffered_spriteram[offs + 3] - 0x100 * (attributes & 0x01)

	move.b	(TARGET_SPRITE_X,a0),d0
	moveq	#0,d1
	move.b	(TARGET_SPRITE_Y,a0),d1


	.ifne	SPRITE_Y_CORRECTION
	add.w	#SPRITE_Y_CORRECTION,d1
	.endif
	.ifne	SPRITE_X_CORRECTION
	add.w	#SPRITE_X_CORRECTION,d0
	.endif
	
	* tile_code = buffered_spriteram[offs] + ((attributes << 2) & 0x300)
	moveq	#0,d2
	move.b	(TARGET_SPRITE_ATTRIBUTES,a0),d2
	btst	#0,d2
	jeq		0f
	sub.w	#0x100,d0
0:
	and.b	#0xC0,d2
	lsl.w	#2,d2
	move.b	(TARGET_SPRITE_CODE,a0),d2
	
	rts
	
update_one_bob:

	move.l	A0,-(a7)
	* Y/X = 0xF8 (raw): nothing displayed
	move.w	(a0),d3
	cmp.w	#0xF8F8,d3
	jeq		2f
0:
	jbsr	compute_sprite_xy_code
	tst.w	d1
	jmi		0f			| (slightly) negative: accept/clip it
	cmp.w	#240,d1		| too low: scrap it
	jcc		2f
	tst.w	d0
	* if X < -32 don't display it (-16 doesn't seem enough)
	jpl		0f
	cmp.w	#-32,d0
	jcs 	2f
0:
	* handle custom amiga horizontal grouping (saves a lot of blitter masking)
	* the table holds several info bits
	* - if 0, this is a normal sprite, no horizontal grouping
	* - if >0, this is a grouped sprite, it also has bit 0 set (to differentiate
	* as sprite 0 is grouped) and is encoded on 1..15 bits (*2)
	*   it repeats the sprite number in the table, only display if not mirrored
	* - if >0 but bit 14 set, never draw
	* - if <0, this is the other half part of the sprite, only display if mirrored
	* it also has bit 0 set
	* that's why we negate the value if mirror (saves a lot of combinations) and test if positive in all cases
	*
	* so for instance, boss sprite 0x2C0 is grouped with 0x2C1, 0x2C2, 0x2C3 (boss has 4 tiles)
	* at offset 0x2C0*2 the table contains the following 16-bit words
	* .word   0x0581,0x4000,0x4000,0xfa81
	* 0x581 divided by 2 = 0x2C0 and 0xfa81 without bit 0 divided by 2 = 0x2C0 as well
	*
	* only sprite 0x2C0 is registered in the base, and is displayed mirrored when game
	* tries to display sprite 0x2C3 mirrored
	* 
	*
	move.b	(TARGET_SPRITE_ATTRIBUTES,a0),d3
	
	.if		OPT_MIRROR_TEST==1
	bset	#MIRROR_BIT,d3
	move.b	d3,(TARGET_SPRITE_ATTRIBUTES,a0)
	.endif
	
	lea		sprite_group_table(pc),a3
	add.w	d2,d2				| code times 2
	move.w	(a3,d2.w),d4
	jeq		10f			| nothing to do, normal tile
	* double/triple/quadruple, whatever
	btst	#14,d4
	jne		2f		| bit 14 set: center tile, never draw
	bclr	#0,d4	| remove bit 0 now
	asr.w	#1,d4	| divide by 2, signed
	btst	#MIRROR_BIT,d3
	jeq		101f
	* mirror: "negate" the code by flipping bit 10
	bchg	#10,d4
101:
	btst	#10,d4
	jne		2f		| no need to draw this part, the other part will do it
	move.w	d4,d2	| get the real sprite code to draw
	add.w	d2,d2	| code times 2
10:
	add.w	d2,d2				| code times 4 now

	move.l	(a4,d2.w),d4		| get pointer from shared bob table
	jne		200f
	* not in the shared bob table. Is it in the level specific bob table?
	move.l	context_sprite_table_ptr,a3
	move.l	(a3,d2.w),d4		| get pointer from specific bob table	
	.ifdef	RELEASE
	jeq		2f				| can theorically happen as sprite update is not atomic (it could be...)
	.else
	jne		100f
	* in dev mode, break if we try to display a non-existing bob

	moveq	#0,d2
	move.b	(TARGET_SPRITE_ATTRIBUTES,a0),d2
	and.b	#0XC0,d2
	lsl.w	#2,d2
	move.b	(TARGET_SPRITE_CODE,a0),d2
	move.b	(TARGET_SPRITE_ATTRIBUTES,a0),d3
	COLOR0_FLASH	0xF00
	*BREAKPOINT	"unregistered sprite clut (D2=code, D3=attribute)"
	jra		2f
100:
	.endif
200:
	* now select proper clut
	move.l	d4,a0
	moveq	#0,d2
	move.b	d3,d2
	lsr.b	#4,d2
	and.b	#0x3,d2
	.ifdef MC68020
	move.l	(a0,d2.w*4),d4
	.else
	add.w	d2,d2
	add.w	d2,d2
	move.l	(a0,d2.w),d4
	.endif
	jeq		2f		| invalid clut: can happen in transition phases
	move.l	d4,a0

	move.w	(a0)+,d4		| height
	move.w	(a0)+,d5		| width
	add.w	(a0)+,d1		| add offset to Y
	* A0 points on the first bitplane of the bob
	addq 	#2,a0

* now we have to check if mirror must be performed, either by doing this in-place
* or by selecting already mirrored data
	lea		((NB_PLAYFIELD_PLANES+1)*4,a0),a1		| load mirrored data pointers
	tst.w	(a1)
	jmi		101f		| invalid pointers: we must do in-place
	btst	#MIRROR_BIT,d3
	jeq		102f
	* to mirror, just change pointer list
	move.l	a1,a0
	* and skip mirroring bit
	jra		103f
101:
	btst	#MIRROR_BIT,d3
102:
	sne		d3		| convert attribute to boolean 0/ff for mirror_sprite_planes
	jbsr	mirror_sprite_planes
103:	
	* BOBs must follow screen scroll
	add.w	bobs_game_scroll_y,d1
	add.w 	bobs_host_scroll_x,d0
	
	* D0 and D1 are already set
	move.l	(NB_PLAYFIELD_PLANES*4,a0),d2
	beq.b	2f		| mask is zero: blank tile => skip
	
	move.l		playfield_drawed_screen_ptr(pc),a1
	
	move.l	d2,a3
	* now 2 cases: if Y is negative, we have to clip, else normal
	tst		d1
	jpl		8f
	* negative: can happen specially on vertical levels
	* convert that to clip
	add.w	d1,d4		| reduce height
	jeq		2f
	jmi		2f			| too high => skip
	neg		d1			| make it positive again
	* now multiply d1 by number of bytes per bob source row
	* we only have 2 cases here: 4 and 6 (technically big boss 
	* could qualify but it doesn't happen)
	add.w	d1,d1		| times 2
	cmp.w	#6,d5
	jne		7f
	add.w	d1,d1		| times 4 (double width)
7:
	move.w	d5,d2			| width in bytes, 4 for 16 pixels+shift
	move.w	d1,d5		| set Y offset
	moveq	#0,d1		| and coord = 0

	
	* store attributes for clipped sprite erase (unless blocked)
	move.w	d0,(a6)+			| store current sprite attributes to previous ones
	clr.w	(a6)+			    | store current sprite attributes to previous ones
	move.w	d4,(a6)+			| store height
	move.w	d2,(a6)+			| store width in bytes

	jra		9f

8:
	cmp.w	#BG_NB_LINES,d1
	jcc		2f		| avoid out of screen

	* note down that this bob will have to be erased
	* store attributes for non-clipped sprite erase



	* store attributes for clipped sprite erase (unless blocked)
	move.w	d0,(a6)+			| store current sprite attributes to previous ones
	move.w	d1,(a6)+			| store current sprite attributes to previous ones
	move.w	d4,(a6)+			| store height
	move.w	d5,(a6)+			| store width in bytes

	move.w	d5,d2			| width in bytes, 4 for 16 pixels+shift
	moveq	#0,d5			| Y-offset

9:
	moveq	#NB_PLAYFIELD_PLANES,d3

	jbsr	blit_planes_any_internal_cookie_cut
2:
	move.l	(a7)+,a0
	rts


* < A0: plane list
* < D3: required orientation
* < D4: height
* < D5: width (bytes) including 16 bit shift
* trashes: only unused registers :) D6,A3

mirror_sprite_planes:
	movem.l	d0-d2/a0,-(a7)
	* bitplanes aren't pre-computed: check bitplanes current orientation and swap
	* if required. This is slow but saves memory
	.if		OPT_BLIT_CHAIN_MODE==0
	lea		mirror_table,a1
	.endif
	moveq	#NB_PLAYFIELD_PLANES+1-1,d6
	lea		mirror_function_table(pc),a3
	.ifndef	MC68020
	move.w	d5,d0       | number of byte values (ex: 4: 16 bits + shifting)
	add.w	d0,d0
	move.l	(a3,d0.w),a3
	.else
	move.l	(a3,d5.w*2),a3		| compute mirror function once and for all
	.endif
0:
	move.l	(a0)+,d1		| current plane data
	jeq		1f				| no data: skip
	move.l	d1,a2
	cmp.b	(-2,a2),d3		| 2 bytes before: mirror flag
	jeq		1f
	* not the proper orientation: change it
	move.b	d3,(-2,a2)
	* perform or queue the mirroring
	WRITE_BLITTER_VIRTUAL_MIRROR	d4,a3,a2

	* next bitplane
1:
	dbf		d6,0b
	movem.l	(a7)+,d0-d2/a0
	rts
	

* < A1: mirror table
* < A2: bitmap
* < D1+1: height
* destroys d0-d2, a2

mirror_16_bit_wide:
	.ifdef	MC68020
	moveq	#0,d2
	.endif
10:
	.ifndef	MC68020
	* we have to do that each time as we must add offsets as long (table is 128k long)
	moveq	#0,d2
	.endif
	move.w	(a2)+,d2
	jeq		14f					| zero: optim
	.ifndef	MC68020
	add.l	d2,d2
	move.w	(a1,d2.l),(-2,a2)   | use .l as d2.w may be > 0x7FFF
	.else
	move.w	(a1,d2.l*2),(-2,a2)
	.endif
14:
	dbf		d1,10b		| next
	rts

mirror_32_bit_wide:
	.ifdef	MC68020
	moveq	#0,d0
	.endif
10:
	.ifndef	MC68020
	* we have to do that each time as we must add offsets as long (table is 128k long)
	moveq	#0,d0
	.endif
	move.l	(a2)+,d2
	jeq		14f		| if line is blank, no need to mirror
	move.w	d2,d0
	clr.w	d2
	swap	d2
	.ifndef	MC68020
	add.l	d2,d2
	add.l	d0,d0
	move.w	(a1,d2.l),-(a2)		| get mirror value
	move.w	(a1,d0.l),-(a2)		| get mirror value
	.else
	move.w	(a1,d2.l*2),-(a2)		| get mirror value
	move.w	(a1,d0.l*2),-(a2)		| get mirror value
	.endif
	addq	#4,a2					| skip row
14:
	dbf		d1,10b
	rts


mirror_48_bit_wide:
	.ifdef	MC68020
	moveq	#0,d0
	moveq	#0,d2
	.endif
10:
	.ifndef	MC68020
	* we have to do that each time as we must add offsets as long (table is 128k long)
	moveq	#0,d0
	moveq	#0,d2
	.endif
	move.w	(a2),d2
	move.w	(4,a2),d0
	* edges
	.ifndef	MC68020
	add.l	d2,d2
	add.l	d0,d0
	move.w	(a1,d2.l),(4,a2)		| get mirror value
	move.w	(a1,d0.l),(a2)+		| get mirror value
	.else
	move.w	(a1,d2.l*2),(4,a2)		| get mirror value
	move.w	(a1,d0.l*2),(a2)+		| get mirror value
	.endif
	* center
	.ifndef	MC68020
	* we have to do that each time as we must add offsets as long (table is 128k long)
	moveq	#0,d2
	.endif
	move.w	(a2),d2
	.ifndef	MC68020
	add.l	d2,d2
	move.w	(a1,d2.l),(a2)
	.else
	move.w	(a1,d2.l*2),(a2)
	.endif
	addq	#4,a2					| skip row
	dbf		d1,10b
	rts


mirror_64_bit_wide:
	.ifdef	MC68020
	moveq	#0,d0
	moveq	#0,d2
	.endif
10:
	.ifndef	MC68020
	moveq	#0,d0
	moveq	#0,d2
	.endif
	
	move.w	(a2),d2
	move.w	(6,a2),d0
	* swap edges
	.ifndef	MC68020
	add.l	d2,d2
	add.l	d0,d0
	move.w	(a1,d2.l),(6,a2)		| get mirror value
	move.w	(a1,d0.l),(a2)+		| get mirror value
	* swap center words
	moveq	#0,d0
	moveq	#0,d2
	move.w	(a2)+,d2
	move.w	(a2),d0
	add.l	d2,d2
	add.l	d0,d0
	move.w	(a1,d2.l),(a2)
	move.w	(a1,d0.l),-(a2)
	.else
	* 68020+ is handy here as scaling doesn't corrupt MSW
	move.w	(a1,d2.l*2),(6,a2)		| get mirror value
	move.w	(a1,d0.l*2),(a2)+		| get mirror value
	* swap center words
	move.w	(a2)+,d2
	move.w	(a2),d0
	move.w	(a1,d2.l*2),(a2)
	move.w	(a1,d0.l*2),-(a2)
	.endif
	addq	#6,a2					| skip row
	dbf		d1,10b
	rts

	
mirror_function_table:
	.long	nope
	.long	nope
	.long	mirror_16_bit_wide
	.long	mirror_32_bit_wide
	.long	mirror_48_bit_wide
	.long	mirror_64_bit_wide
	.long	nope		| just in case, but there are no such objects
	.long	nope

nope:
	rts
	
	
* < D0,D1: x,y
* < A1: foreground plane pointer (often first plane!)
* < D2: width in bytes (inc. 2 extra for shifting)
* < D3: nb planes to clear
* < D4: blit height


* trashes D0-D6/A2
clear_planes_any_blitter_internal:
    * pre-compute the maximum of shit here
	move.w	d1,d6
    beq.b   1f    | optim
	* check if y start + height > Y_MAX
	* (ignores case where y = 0, no risk)
	add.w	d4,d6
	sub.w	#Y_MAX,d6
	bmi.b	0f
	* y start + height > Y_MAX: clip height
	sub.w	d6,d4
	beq.b	10f
	bpl.b	0f
10:
	* null or negative height after clipping: out
	rts
0:
    lea mulBG_NB_BYTES_PER_ROW_table(pc),a2
    add.w   d1,d1
    move.w  (a2,d1.w),d1
1:
    and.w   #0x1F0,d0
    beq.b   2f				| zero X optimization
    lsr.w   #3,d0
    add.w   d0,d1
2:   
    add.w   d1,a1       | plane position (always even)

	* reuse d1 for bltcon0
	moveq	#1,d1
	ror.l	#8,d1     | AKA move.l  #0x01000000,d1   | minterm useD & rect clear (0xA) 

	move.w #BG_NB_BYTES_PER_ROW,d0
	bclr	#0,d2		| make sure D2 is even (else strange things occur!)
    sub.w   d2,d0       | blit width

	move.w	d4,d6		| save height
    lsl.w   #6,d4
    lsr.w   #1,d2
    add.w   d2,d4       | blit height+width
	moveq	#-1,d2
    * now just wait for blitter ready to write all registers
	WAIT_BLIT
    
	WRITE_BLITTER_REG_LONG	d2,bltafwm
	WRITE_BLITTER_REG_LONG	d1,bltcon0	
	WRITE_BLITTER_REG_WORD	d0,bltdmod	|D modulo
	
	subq	#1,d3
	jeq		4f
3:
	WAIT_BLIT
	WRITE_BLITTER_REG_LONG	a1,bltdpt	|destination top left corner
	WRITE_BLITTER_REG_SIZE	d4	|rectangle size, starts blit
32:
	.if	BG_SCREEN_PLANE_SIZE>0x7FFF
	add.l	#BG_SCREEN_PLANE_SIZE,a1
	.else
	add.w	#BG_SCREEN_PLANE_SIZE,a1
	.endif
	dbf		d3,3b
4:
	rts
	
	
	
* < A5: custom
* < D0.W,D1.W: x,y, no shifting
* < A0: source (pointer on array of planes)
* < A1: destination fg plane
* < D2: width in bytes
* < D3: number of planes
* < D4: height. If negative, source is copied with negative modulo (flip)
* < D5: y offset for source planes
* < D7: blit mask (not considered, optim, -1 all through the game)
* blit mask set
* returns: start of destination in A1 (computed from old A1+X,Y)
* trashes: a1
blit_planes_any_internal_no_cookie_cut:
    movem.l d0-d7/a4,-(a7)
    * pre-compute the maximum of shit here
	tst.w	d4
	bpl.b	1f
	sub.w	d4,d1	| pre-add height to d1
	subq.w	#1,d1	| minus one
1:	
	tst	d1
    beq.b   2f    | optim
    lea		mulBG_NB_BYTES_PER_ROW_table,a4
	.ifdef	NO68020
	add.w	d1,d1
    move.w  (a4,d1.w),d1	| y times 40
	.else
    move.w  (a4,d1.w*2),d1	| y times 40
	.endif
2:
	
    asr.w   #3,d0			| X displacement in bytes

    add.w   d0,d1

	move.l  #0x09f00000,d7    | A->D copy, ascending mode
	move.l  #0x0FCA0000,d6     | D clear

    * make offset even. Blitter will ignore odd address
    * but a 68000 CPU doesn't and since we RETURN A1...
    *bclr    #0,d1
    add.w   d1,a1       | plane position (D1 < 0x7FFF, 288*40=0x2D00)
	move.w	#BG_NB_BYTES_PER_ROW,d0
	tst.w	d4
	bpl.b	5f
	neg.w	d0
	neg.w	d4    | make d4 positive again
5:
    sub.w   d2,d0       | blit width
    lsl.w   #6,d4
    lsr.w   #1,d2
    add.w   d2,d4       | blit height
    * always the same settings (ATM)
	moveq	#-2,d2
	
    * now just wait for blitter ready to write all registers
	WAIT_BLIT
    
    * blitter registers set

	WRITE_BLITTER_REG_WORD	#0,bltalwm
	WRITE_BLITTER_REG_WORD	d2,bltamod		|A modulo=bytes to skip between lines
	
	WRITE_BLITTER_REG_WORD	d0,bltdmod	|D modulo
					
	subq	#1,d3
	jeq	7f
	subq	#1,d3
6:
	jbsr	start_process_1_plane_nocc
	
	WRITE_BLITTER_REG_LONG	a1,bltdpt	|destination top (bottom) left corner
	DO_BLIT	|rectangle size, starts blit
	.if	BG_SCREEN_PLANE_SIZE > 0x7FFF
	add.l	#BG_SCREEN_PLANE_SIZE,a1
	.else
	add.w	#BG_SCREEN_PLANE_SIZE,a1
	.endif
	WAIT_BLIT
	dbf		d3,6b
7:
	jbsr	start_process_1_plane_nocc
	WRITE_BLITTER_REG_LONG	a1,bltdpt	|destination top (bottom) left corner
	DO_BLIT	|rectangle size, starts blit
    
    movem.l (a7)+,d0-d7/a4
    rts
	
start_process_1_plane_nocc:
	move.l (a0)+,d0
	jne	61f

	* source is 0: just clear (less bandwidth lost) and change bltcon
	WRITE_BLITTER_REG_LONG	#0x01000000,bltcon0	| sets con0 and con1: clear

	rts
61:
	* non-zero: set data source & bltcon
	WRITE_BLITTER_REG_LONG	d7,bltcon0	| sets con0 and con1: C-A+B->D cookie cut full
	WRITE_BLITTER_REG_LONG	d0,bltapt	| source graphic top left corner
	rts


* < A5: custom
* < D0.W,D1.W: x,y
* < A0: source (pointer on array of planes)
* < A1: destination fg plane, also background to mix with cookie cut fg plane
* < A3: source mask for cookie cut
* < D2: width in bytes (inc. 2 extra for shifting)
* < D3: number of planes
* < D4: height. If negative, source is copied with negative modulo (flip)
* < D5: y offset for source planes
* < D7: blit mask (not considered, optim, -1 all through the game)
* blit mask set
* returns: start of destination in A1 (computed from old A1+X,Y)
* trashes: a1
blit_planes_any_internal_cookie_cut:
    movem.l d0-d7/a4,-(a7)
    * pre-compute the maximum of shit here
	tst.w	d4
	bpl.b	1f
	sub.w	d4,d1	| pre-add height to d1
	subq.w	#1,d1	| minus one
1:	
	tst	d1
    beq.b   5f    | optim
	
4:	
    lea		mulBG_NB_BYTES_PER_ROW_table(pc),a4
	.ifndef	MC68020
	add.w	d1,d1
    move.w  (a4,d1.w),d1	| y times 40
	.else
    move.w  (a4,d1.w*2),d1	| y times 40
	.endif
5:
	lea		cookie_cut_blit_table(pc),a4
	
    move.w  d0,d6
    lsr.w   #3,d0			| X displacement in bytes
	*bclr	#0,d0			| no need, it will be even
    and.w   #0xF,d6
	.ifndef	MC68020
	add.w	d6,d6
	add.w	d6,d6
	move.l	(a4,d6.w),d7
	lea		cookie_cut_mask_blit_table(pc),a4
	move.l	(a4,d6.w),d6
	.else
	move.l	(a4,d6.w*4),d7
	lea		cookie_cut_mask_blit_table(pc),a4
	move.l	(a4,d6.w*4),d6
	.endif
3:   
    add.w   d0,d1
4:
    * make offset even. Blitter will ignore odd address
    * but a 68000 CPU doesn't and since we RETURN A1...
    *bclr    #0,d1
    add.w   d1,a1       | plane position (D1 < 0x7FFF, 288*40=0x2D00)
	move.w	#BG_NB_BYTES_PER_ROW,d0
	tst.w	d4
	bpl.b	5f
	neg.w	d0
	neg.w	d4    | make d4 positive again
5:
    sub.w   d2,d0       | blit width
    lsl.w   #6,d4
    lsr.w   #1,d2
    add.w   d2,d4       | blit height
    * always the same settings (ATM)
	moveq	#-2,d2
	add.w	d5,a3			| apply y offset to mask too (y offset looks wrong)
	
    * now just wait for blitter ready to write all registers
	WAIT_BLIT
    
    * blitter registers set

	WRITE_BLITTER_REG_WORD	d2,bltamod		|A modulo=bytes to skip between lines
	WRITE_BLITTER_REG_WORD	d2,bltbmod		|B modulo=bytes to skip between lines
	moveq	#0,d2
	WRITE_BLITTER_REG_WORD	d2,bltalwm	    | so the -2 modulo trick works
	
	WRITE_BLITTER_REG_WORD	d0,bltcmod	|C modulo
	WRITE_BLITTER_REG_WORD	d0,bltdmod	|D modulo
					
	subq	#1,d3
	jeq	7f
	subq	#1,d3
6:
	WRITE_BLITTER_REG_LONG	a3,bltapt	|source graphic top left corner (mask)
	jbsr	start_process_1_plane
	
	WRITE_BLITTER_REG_LONG	a1,bltcpt	|pristine background top (bottom) left corner
	WRITE_BLITTER_REG_LONG	a1,bltdpt	|destination top (bottom) left corner
	WRITE_BLITTER_REG_SIZE	d4	|rectangle size, starts blit
	.if	BG_SCREEN_PLANE_SIZE > 0x7FFF
	add.l	#BG_SCREEN_PLANE_SIZE,a1
	.else
	add.w	#BG_SCREEN_PLANE_SIZE,a1
	.endif
	WAIT_BLIT
	dbf		d3,6b
7:
	WRITE_BLITTER_REG_LONG	a3,bltapt	|source graphic top left corner (mask)
	jbsr	start_process_1_plane
	WRITE_BLITTER_REG_LONG	a1,bltcpt	|pristine background top (bottom) left corner
	WRITE_BLITTER_REG_LONG	a1,bltdpt	|destination top (bottom) left corner
	WRITE_BLITTER_REG_SIZE	d4	|rectangle size, starts blit
10:
    movem.l (a7)+,d0-d7/a4
    rts
	
start_process_1_plane:
	move.l (a0)+,d0
	beq.b	60f
	move.l	d0,a4
	add.w	d5,a4		| add Y offset
	jra		61f
60:
	* source is 0: just apply mask (less bandwidth lost) and change bltcon
	WRITE_BLITTER_REG_LONG	d6,bltcon0	| sets con0 and con1: C-A->D cookie cut, B fixed
	WRITE_BLITTER_REG_WORD	d2,bltbdat	|B word is zero
	rts
61:
	* non-zero: set data source & bltcon
	WRITE_BLITTER_REG_LONG	d7,bltcon0	| sets con0 and con1: C-A+B->D cookie cut full
	WRITE_BLITTER_REG_LONG	a4,bltbpt	|source graphic top left corner
	rts

	.macro	GEN_MINTERM_TABLE	name,value
\name\()_table:
	.set	shift,0
	.rept	16
	.long	(shift<<28)+(shift<<12)+(\value<<16)
	.set	shift,shift+1
	.endr
	.endm
	
	.macro	GEN_MINTERM_TABLE_2	name,value
\name\()_table:
	.set	shift,0
	.rept	16
	.long	(shift<<28)+(\value<<16)
	.set	shift,shift+1
	.endr
	.endm
	
	GEN_MINTERM_TABLE	cookie_cut_blit,0x0FCA
	GEN_MINTERM_TABLE_2	cookie_cut_mask_blit,0x0BCA



bank_base:
	.long	0
bank_table:
	.long	0
	.long	maincpu_bank1-0x4000
	.long	maincpu_bank2-0x4000
	.long	maincpu_bank3-0x4000
	.long	maincpu_bank4-0x4000
	.long	maincpu_bank5-0x4000
	
bob_previous_positions_1:
	.fill NB_TARGET_SPRITES*PREVIOUS_SPRITE_SIZE , 1 , -1
	
bob_previous_drawed_sprites:
	.long	bob_previous_positions_1
bob_previous_displayed_sprites:
	.ifeq	OPT_ENABLE_DOUBLE_BUFFERING
	.long	bob_previous_positions_1
	.else
	.long	bob_previous_positions_2	
bob_previous_positions_2:
	.fill NB_TARGET_SPRITES*PREVIOUS_SPRITE_SIZE , 1 , -1

	.endif

	
	.ifne	OPT_ENABLE_DOUBLE_BUFFERING
switch_screen_buffers:

	* let's switch screen buffers, background (chars)
	* toggle fg planes (double buffering)
	* also toggle previous sprite positions
	lea		playfield_drawed_screen_ptr(pc),a0
	lea		bob_previous_positions_1(pc),a2
	lea		bob_previous_positions_2(pc),a3
	move.l	playfield_screen_data_1,a1
	move.l	playfield_screen_data_2,a5
	* also switch previous state memory
	cmp.l	(a0),a1
	bne.b	2f
	* screen data 1 is displayed screen
	* set it to drawn screen
	exg		a1,a5
	exg		a2,a3
2:
	move.l	a1,(a0)
	move.l	a5,playfield_displayed_screen_ptr
	move.l	a3,bob_previous_displayed_sprites
	move.l	a2,bob_previous_drawed_sprites

	jbra		set_bobs_bitplanes
	.endif
	
	
store_system:
	tst.l	_resload
	beq.b	0f
	rts
0:
	* system copper
	
	move.l	4.W,a6
	move.w	AttnFlags(a6),d0
	btst	#AFB_68010,d0
	beq.b	1f
	lea	get_vbr,a5

	jsr		_LVOSupervisor(a6)
	move.l	d0,system_vbr
1:
	

	lea	_custom,a6
	move.w	intenar(a6),old_intena
	move.w	dmaconr(a6),old_dmacon
	lea		old_sysvectors,a0
	move.l	system_vbr(pc),a1
	move.l	(0x64,a1),(a0)+
	move.l	(0x68,a1),(a0)+
	move.l	(0x6c,a1),(a0)+
	move.l	(0x70,a1),(a0)+
	move.l	(0x74,a1),(a0)+
	move.l	(0x78,a1),(a0)+
	move.l	(0x7C,a1),(a0)+
	rts

restore_system:
	move.l	system_vbr(pc),a0
	lea	_custom,a6
	jsr		_mt_remove_cia

	move.w	#0x4000,intena(a6)	| ints off
	lea		old_sysvectors,a0
	move.l	system_vbr(pc),a1
	move.l	(a0)+,(0x64,a1)
	move.l	(a0)+,(0x68,a1)
	move.l	(a0)+,(0x6c,a1)
	move.l	(a0)+,(0x70,a1)
	move.l	(a0)+,(0x74,a1)
	move.l	(a0)+,(0x78,a1)
	move.l	(a0)+,(0x7C,a1)


	bclr	#6,0xbfee01


	lea	_custom,a6
	move.w	old_intena,d0			| get old val
	and.w	#0x3fff,d0
	eor.w	#0x3fff,d0
	move.w	d0,intena(a6)		| clr bits
	eor.w	#0x3fff,d0
	or.w	#0xc000,d0		
	move.w	d0,intena(a6)		| set bits and main

	move.w	old_dmacon,d0			| get old val
	and.w	#0x3fff,d0
	eor.w	#0x3fff,d0

***		and.w	#0xfff0,d0		| preserve sound dma for now

	move.w	d0,dmacon(a6)		| clr bits



	eor.w	#0x3fff,d0
	or.w	#0xc000,d0		
	move.w	d0,dmacon(a6)		| set bits and main

	move.l	old_syscoplist,cop1lc(a6)
	move.l	_gfxbase,a6
	move.b	gb_ChipRevBits0(a6),chiprevbits+3
	move.l	old_actiview,a1
	jsr	_LVOLoadView(a6)


	moveq	#0,d0
	rts


	
platform_init:
	bsr		store_system
	

	lea		_custom,a5
	move.w	#0x7FFF,dmacon(a5)
	move.w	#0x7FFF,intena(a5)
	* set blitter parameters
	move.l	#-1,bltafwm(a5)
	
	move.l	monitor,d0
	cmp.l	#NTSC_MONITOR_ID,D0
	bne		0f
	st.b	ntsc_flag
	* disable extra mid-screen interrupt, as it would be too fast (NTSC)
	move.w	#COPPER_NOP,pal_intreq_block_game
	* also change screen start position, make it higher
	move.w	#0x01+(0xC<<8),screen_start
	sub.b	#8,weapon_palette_wait_value
	
	*move.w	#0x0401,pal_wait			| else intreq never happens
0:
	.if		NB_PLAYFIELD_PLANES==8
    move.w #0x0210+BORDERBLANK,bplcon0(a5) | 8 bitplanes, borderblank
	.else
    move.w #0x200+BORDERBLANK+(NB_PLAYFIELD_PLANES<<12),bplcon0(a5) | 8 > nb bitplanes, borderblank
	.endif
    move.w #BASE_BPLCON2_VALUE,bplcon2(a5)


 	*         VVHH
    move.w #0x89+((Y_START+0x10)<<8),d0
    move.w #0x89+((Y_START)<<8),d1
	cmp.l	#NTSC_MONITOR_ID,monitor
	jne		0f
	sub.w	#NTSC_Y_SHIFT<<8,d0
	sub.w	#NTSC_Y_SHIFT<<8,d1
0:	
	* AGA

	.ifne	OPT_AGA_MODE
    move.w #BASE_BPLCON4_VALUE,bplcon4(a5)
    move.w #0x0C00+BORDERBLANK<<5,bplcon3(a5)     | no AGA specificities, default ECS
    add	#AGA_X_SHIFT,d0
    add	#AGA_X_SHIFT,d1
	.endif
	
    move.w d0,diwstrt(a5)
    move.w d1,diwstop(a5)
    move.w #0x0038,ddfstrt(a5)

	move	#BG_NB_BYTES_PER_ROW-40,d0

	.ifne	OPT_AGA_MODE
    move.w #0x00C0,ddfstop(a5)		| C0 for fmode=3
	move.w	#(3<<2)+3,fmode(a5)		| wide sprites, faster fetch
	subq	#8,d0			| change modulo
 	.else
	move.w #0x00D0,ddfstop(a5)		| C0 for fmode=3
	.endif
	
	* 0 modulo (OCS)
    move.w d0,bpl1mod(a5)
    move.w d0,bpl2mod(a5)

	.ifdef	NEED_ROWS
	lea		rows_table,a1
	* generate a contiguous pointer table for copperlist row entries
	* we cannot have a contiguous copperlist because we need to insert
	* stuff now and then (ntsc emulation, color change, PAL wait)
	lea		first_rows,a0
	move.w	#NB_FIRST_ROWS,d0
	jbsr	generate_row_table
	lea		second_rows,a0
	move.w	#NB_SECOND_ROWS,d0
	jbsr	generate_row_table
	lea		third_rows,a0
	move.w	#NB_THIRD_ROWS,d0
	jbsr	generate_row_table
	lea		fourth_rows,a0
	move.w	#NB_FOURTH_ROWS,d0
	jbsr	generate_row_table
	.endif
	
	* install jump for palette switch
	move.l	#after_osd_lower_palette,d0
	lea		osd_lower_palette_switch_address,a0
	move.w	d0,(6,a0)
	swap	d0
	move.w	d0,(2,a0)
	
	lea		hw_sprite_ram_buffer,a0
	jbsr	align_for_fmode
	moveq	#7,d0
	lea		hw_sprite_pointers,a1
0:
	move.l	a0,(a1)+
	add.w	#HW_SPRITE_BUFFER_SIZE,a0
	dbf		d0,0b
	
	lea		bobs_screen_buffer_1,a0
	addq	#2,a0	| leave 16 bits hidden for left side clipping
	jbsr	align_for_fmode
	move.l	a0,playfield_screen_data_1
	move.l	a0,playfield_drawed_screen_ptr
	move.l	a0,playfield_displayed_screen_ptr
	
	st		music_track_start_number

	.ifne	OPT_ENABLE_DOUBLE_BUFFERING
	lea		bobs_screen_buffer_2,a0
	addq	#2,a0	| leave 16 bits hidden for left side clipping
	jbsr	align_for_fmode
	move.l	a0,playfield_screen_data_2
	move.l	a0,playfield_displayed_screen_ptr
	.endif
		
	* init color table handling the bank switch issue
	lea		copperlist_colors,a0
	lea		color_copper_pointers,a1
	moveq	#(TOTAL_NB_COLORS/32),d0		| nb banks for all colors + sprite color bank
0:
	.ifne	OPT_AGA_MODE
	addq.w	#4,a0		| skip set bank
	.endif
	move.w	#31,d1		| 32 colors per bank
1:
	move.l	a0,(a1)+
	addq.w	#4,a0
	dbf		d1,1b
	dbf		d0,0b
	
	
	
	* put static sprite entries, we'll write into
	* that sprite area
	lea		game_sprites,a2
	lea		hw_sprite_pointers,a1
1:
	move.l	(a1)+,d0
	move.w	d0,(6,a2)
	swap	d0
	move.w	d0,(2,a2)
	*swap	d0
	addq	#8,a2
	cmp.l	#game_sprites_end,a2
	bcs		1b
2:
	* compute control words for each sprite pair
	lea		hw_sprite_pointers,a0
	lea		HW_SpriteYTable_256,a1
	moveq	#3,d7
	moveq	#0x3F,d2	| sprite X start
0:
	move.w	d2,d0
	move.w	#0x14,d1
	tst.b	ntsc_flag
	jeq		1f
	sub.w	#12,d1		| sprites slightly higher
1:
	jbsr	store_sprite_pos
	add.w	#64,d2		| advance X
	
	* store control word
	.rept	2
	move.l	(a0)+,a2
	move.w	d0,(8,a2)
	swap 	d0
	move.w	d0,(a2)
	swap	d0
	bset	#7,d0		| attach bit
	addq	#8,a2
	.endr
	
	dbf	d7,0b

	
		
	
*	lea		sprite_palette,a0
*	move.l	color_copper_pointers+TOTAL_NB_COLORS/2*4,a1	| entries 32-64
*	move.w	#TOTAL_NB_COLORS/2,d0
*	jbsr	load_palette
	
	
	jbsr		set_bobs_bitplanes
	
	
	lea		_custom,a5
	lea		game_copperlist,a0
	move.l	a0,cop1lc(a5)

	

	* wait 300 lines
	move.w	#100,d0
	bsr	beamdelay
	move.w	#100,d0
	bsr	beamdelay
	move.w	#100,d0
	bsr	beamdelay
	
    * init sprite, bitplane, whatever dma

    move.w #0x83E0,dmacon(a5)
 

	* install keyboard and vblank/copper handler
	move.l	system_vbr(pc),a1
	pea		level1_interrupt(pc)
	move.l	(a7)+,(0x64,a1)
	pea		level2_interrupt(pc)
	move.l	(a7)+,(0x68,a1)
	pea		level3_interrupt(pc)
	move.l	(a7)+,(0x6C,a1)
	pea		_nmi(pc)
	move.l	(a7)+,(0x7C,a1)

	* soundfx lib
	lea		_custom,a6
	lea		blank_sound,a0
	move.l	a0,(0xA0,a6)
	move.l	a0,(0xB0,a6)
	move.l	a0,(0xC0,a6)
	move.l	a0,(0xD0,a6)
	move.l	system_vbr(pc),a0
	moveq	#1,d0	| PAL
	jsr		_mt_install_cia



	
	
    rts
	
* < A0: palette
* < A1: copperlist
* < D0: number of colors to load	
load_palette:
	subq.w	#1,d0
	beq.b	2f
1:
	addq.w	#2,a1
	move.w	(a0)+,(a1)+
	dbf		d0,1b
2:
	rts
* < D0: row, if 0: do nothing
wrap_bitplanes:
	movem.l	a0-a2/d0-d3,-(a7)
	* first restore previous wrap if wasn't 0 TODO
	
	* if zero, we stop here, row 0 wraps naturally
	subq	#1,d0
	jmi		2f
	add.w	d0,d0
	add.w	d0,d0
 	lea	rows_table,a2
	add.w	d0,a2
	move.l	(a2),a1
	move.w	#COPPER_NOP,(0x8,a1)	| remove copjmp2, enable what's below
	add		#0x12,a1	| skip preamble
	move.w	#BG_SCREEN_PLANE_SIZE,d2
	move.w	#NB_PLAYFIELD_PLANES,d1
    move.l	playfield_displayed_screen_ptr(pc),d3
	* we should store A1 (double buffering)
1:
    swap d3
    move.w d3,(a1)
    swap d3
    move.w d3,(4,a1)    
    addq.w  #8,a1
    add.l d2,d3
    dbf d1,1b
2:
	movem.l	(a7)+,a0-a2/d0-d3
	rts
* < A0: copper block with rows
* < A1: part of the pointers list
* < D0: number of rows to fill

	.ifdef	NEED_ROWS
generate_row_table:
	* generate row table, set jumps
	move.w	#(first_rows_end-first_rows)/NB_FIRST_ROWS,d7	| block size
	subq	#1,d0
0:
	move.l 	a0,(a1)+
	lea		(a0,d7.w),a2	| next row jump
	move.l	a2,d1
	move.w	d1,(6+4,a0)
	swap	d1
	move.w	d1,(2+4,a0)
	move.l	a2,a0		| next row
	dbf		d0,0b
	rts
	.endif

* works if interrupts enabled or disabled
osd_wait_vblank_interrupt:
	btst	#5,_custom+intenar+1
	jne		1f
0:
	btst	#5,_custom+intreqr+1
	jeq		0b
	* ack afterwards
	move.w	_custom+intreqr,d0
	bclr	#5,d0
	move.w	d0,_custom+intreq
	rts
1:
	* with interrupts enabled, different handling, collaborate with vblank
	* to read the extra bit 3. First set it, then wait for vblank to clear it
	bset	#3,(extra_3802,a6)
2:
	btst	#3,(extra_3802,a6)
	jne		2b
	rts
	
* 60Hz VBLANK interrupt (also keyboard)
* only called at bootup, not from interrupts (at least!!)
osd_enable_interrupts:
	.if		OPT_BLIT_CHAIN_MODE==1
	* enable blitter, vblank & software level 1
	move.w	#0xC06C,_custom+intena
	.else
	* enable vblank & software level 1 only
	move.w	#0xC02C,_custom+intena
	.endif
	rts
osd_disable_interrupts:
	.if		OPT_BLIT_CHAIN_MODE==1
	* leave keyboard
	move.w	#0x0064,_custom+intena
	.else
	move.w	#0x0024,_custom+intena
	.endif
	rts
	


	
	

	
* set bank
* < D0.B bank & other screen attributes & scroll (what a mess)
* > A1 bank pointer minus 0x4000
osd_set_bank:
	movem.l	d0/d1/a0,-(a7)
	move.b	d0,(bankswitch_3808,a6)		| scrolling needs the value
	* make sure D5 is not used there!
	move.b	d0,d1
	lsr.b	#5,d1
	and.w	#7,d1
	cmp.b	current_rom_bank,d1
	jeq		1f
	
	move.b	d1,current_rom_bank
	.ifndef	RELEASE
	cmp.b	#8,d1
	jcs		0f 
	BREAKPOINT	"illegal bank index check D1"
0:
	cmp.b	#6,d1
	jcc		1f			| banks 6 & 7 are empty: do nothing
	.endif
	lea		bank_table,a0
	.ifdef	NO68020
	add.w	d1,d1
	add.w	d1,d1
	move.l	(a0,d1.w),a1
	.else
	move.l	(a0,d1.w*4),a1
	.endif
	move.l	a1,bank_base
1:
	movem.l	(a7)+,d0/d1/a0
	rts

	
osd_clear_bg_screen:
	movem.l	d0/a0/a1,-(a7)
	
	move.l	playfield_drawed_screen_ptr,a0
	move.l	playfield_displayed_screen_ptr,a1
	move.w	#(BG_SCREEN_PLANE_SIZE*NB_BG_PLANES)/16-1,d0
0:
	.rept	4
	clr.l	(a0)+
	clr.l	(a1)+
	.endr
	dbf		d0,0b
	movem.l	(a7)+,d0/a0/a1
	rts
	
* fast way to clear screen
osd_clear_fg_screen:
	
	movem.l	d0/d1/a0/a1,-(a7)
	
	lea		hw_sprite_pointers,a1
	moveq	#7,d1
0:
	move.l	(a1)+,a0
	add.w	#16,a0		| skip control word
	move.w	#HW_SPRITE_BUFFER_SIZE/4-5,d0
1:
	clr.l	(a0)+
	dbf		d0,1b
	dbf		d1,0b
	movem.l	(a7)+,d0/d1/a0/a1
	rts
	
*TILE_GET_INFO_MEMBER(ddragon_state::get_bg_tile_info)
*{
*	tile_index <<= 1;
*	uint8_t const attr = m_bgvideoram[tile_index];
*	tileinfo.set(2,
*			m_bgvideoram[tile_index | 1] | ((attr & 0x07) << 8),
*			(attr >> 3) & 0x07,
*			TILE_FLIPYX((attr & 0xc0) >> 6));
*}
*
*TILE_GET_INFO_MEMBER(ddragon_state::get_fg_tile_info)
*{
*	tile_index <<= 1;
*	uint8_t const attr = m_fgvideoram[tile_index];
*	tileinfo.set(0,
*			m_fgvideoram[tile_index | 1] | ((attr & 0x07) << 8),
*			attr >> 5,
*			0);
*}
	
* a0=screen address (preserved)
* a6=ram base
* should preserve all registers
* allows 1800-1FFF and 3000-37FF range
* 1800: foreground/HUD
* 3000: background
osd_video_word_dirty:
osd_video_byte_dirty:
	OSD_ENTER
	movem.l	d0-d7/a0-a2/a5,-(a7)
	move.b	(a0),d0
	move.l	a0,d7		| save address
	sub.l	a6,d7
	jmi		osd_w_videoram_out

	cmp.w	#BG_SCREEN_TILE_ADDRESS,d7
	jcs		maybe_fg_tile		| lower than 0x3000 ? check fg
	.ifndef		RELEASE
	cmp.w	#BG_SCREEN_TILE_ADDRESS+0x800,d7
	jcs		0f
	BREAKPOINT	"write videoram out of range (D7)"
	jra	osd_w_videoram_out	
	.endif
0:
* bg tile
	and.w	#0x7FE,d7
	lea		(BG_SCREEN_TILE_ADDRESS,a6),a0
	move.b	(a0,d7.w),d1
	move.b	(1,a0,d7.w),d0

	jbsr	update_bg_tile
	jra		osd_w_videoram_out
	
maybe_fg_tile:
	* we now suppose that we're in 1800-2000
	* check that in debug mode
	.ifndef		RELEASE
	cmp.w	#FG_SCREEN_TILE_ADDRESS+0x800,d7
	jcs		0f
1:
	BREAKPOINT	"write videoram out of range (D7)"
	bra.b	osd_w_videoram_out	
0:
	.endif
	
	sub.w	#FG_SCREEN_TILE_ADDRESS,d7
	.ifndef	RELEASE
	jpl		0f
	add.w	#FG_SCREEN_TILE_ADDRESS,d7
	BREAKPOINT	"write videoram out of range (D7)"
	jra		osd_w_videoram_out
0:
	.endif
	
	
	and.w	#0x7FE,d7
	lea		(FG_SCREEN_TILE_ADDRESS,a6),a0
	move.b	(a0,d7.w),d1
	move.b	(1,a0,d7.w),d0

	jbsr	update_fg_tile

osd_w_videoram_out:
	movem.l	(a7)+,d0-d7/a0-a2/a5
	OSD_EXIT
	rts	
	
bg_tile:
	and.w	#0x7FE,d7
	
	* we need to see if the tile is on screen considering X scolling
	* positions. Compute first X & last X coord visible


	lea		dd2gng_table,a0
	move.w	(a0,d7.w),d6
	jbsr	compute_x_offset
	jmi		osd_w_videoram_out
	
	* tile is in screen considered the current scrolling: update it
	* (don't check Y we need update no matter when in that case)
	
	
	lea		(BG_SCREEN_TILE_ADDRESS,a6),a0
	move.b	(1,a0,d7.w),d0
	move.b	(a0,d7.w),d1


	* here we have to compute x_offset, this is the game displaying a random
	* tile on screen

	jbsr	update_bg_tile

	jra		osd_w_videoram_out
	
	
	.macro	COPY_TILE8_PLANE_ROW
	move.b	d0,(offset,a1)  | buffer
	.endm
	
	.macro	CLEAR_TILE8_PLANE
	.set	offset,0
	.rept	8
	clr.b	(offset,a1)
	.set	offset,offset+FG_NB_BYTES_PER_ROW
	.endr	
	.endm
	
	.macro	TILE8_NEXT_PLANE
	add.l	d5,a1
	add.l	d5,a2
	.endm

* compute X offset (0,0x40,0x80 ...) that makes up for
* corkscrew effect
* !only valable for a single random tile poke, not for a scroll column update
* that computes its own x_offset!
* < D6: address (0-0x400) matching Ghosts'N'Goblins layout
* (I'm lazy I'm not going to change that routine it was a pain in the *ss to tune)
* > N: set not in visible screen
* > x_offset: updated
compute_x_offset:
	movem.w	d1-d2,-(a7)
	* we need to see if the tile is on screen considering X scolling
	* positions. Compute first X & last X coord visible
	clr.w	x_offset
	move.w	d6,d2
	lsr.w	#5,d2
	
	* establish min & max bounds including invisible tile used for scroll
	* which is outside the screen
	move.w	game_scroll_x,d0  | left of screen
	lsr.w	#4,d0		| divide by 16 match tile
	move.w	d0,d1
	add.w	#0x12,d1	| right part
	
	* is min X < d2
	cmp.b	d0,d2
	jcc		0f
	move.w	d1,d3
	and.w	#0x1F,d3
	cmp.w	d0,d3
	jcc		0f
	* handle wrap
	add.w	#0x20,d2
	move.w	#0x40,x_offset		| wrapped: add 0x40 offset
0:
	cmp.w	d0,d2
	jcs		10f
	add.w	#0x11,d0			| visible tile span (including invisible scroll column)
	cmp.b	d0,d2
	jcc		10f	| tile x+screen width < scroll x

	* tile is in screen: return x offset (0, 0x40, 0x80 ...)
	
	move.w	host_scroll_x,d0
	* now reduce 0x200 => 0x40
	lsr.w	#8,d0
	lsr.w	#1,d0
	lsl.w	#6,d0
	add.w	d0,x_offset	
2:
	movem.w	(a7)+,d1-d2
	rts
10:
	moveq	#-1,d0
	jra		2b
	
* create 2 caches

cache_bg_tiles_address:
	* 1 cache: tile-accurate X,Y => address
	lea		bg_tile_xy2address_cache,a0
	moveq	#0,d1
0:
	moveq	#0,d0
1:
	move.w	d0,d2
	lsl.w	#5,d2		| X*32
	add.w	d1,d2		| plus Y
	move.w	d2,(a0)+
	addq	#1,d0
	cmp.w	#0x20,d0
	jne		1b
	addq	#1,d1
	cmp.w	#0x20,d1
	jne		0b
	
	* 2 cache: address => tile-accurate X,Y
	lea		bg_tile_address2xy_cache,a0
	move.w	#0,d7
0:
	move.w	d7,d0
	lsr.w	#5,d0
	lsl.w	#8,d0
	move.w	d7,d1
	and.b	#0x1F,d1
	or.b	d1,d0
	move.w	d0,(a0)+
	addq	#1,d7
	cmp.w	#0x400,d7
	jne		0b
	
	rts
	
	.macro	COPY_TILE16_PLANE_ROW
	move.w	d0,(offset,a1)  | buffer
	move.w	d0,(offset,a3)  | restore buffer
	.ifne	OPT_ENABLE_DOUBLE_BUFFERING
	move.w	d0,(offset,a4)	| second buffer
	.endif
	.endm
	
	.macro	CLEAR_TILE16_PLANE
	.set	offset,0
	.rept	16
	clr.w	(offset,a1)
	clr.w	(offset,a3)  | restore buffer
	.ifne	OPT_ENABLE_DOUBLE_BUFFERING
	clr.w	(offset,a4)	| second buffer
	.endif
	.set	offset,offset+BG_NB_BYTES_PER_ROW
	.endr	
	.endm
	

	
	.macro	TILE16_NEXT_PLANE
	.if	BG_SCREEN_PLANE_SIZE>0x7FFF
	add.l	d5,a1
	add.l	d5,a3
	.ifne	OPT_ENABLE_DOUBLE_BUFFERING
	add.l	d5,a4
	.endif
	.else
	add.w	d5,a1
	add.w	d5,a3
	.ifne	OPT_ENABLE_DOUBLE_BUFFERING
	add.w	d5,a4
	.endif
	
	.endif
	.endm
	
* < D7: 0-0x800 address
* < D0: tile code
* < D1: color code
* uses x_offset computed from scrolling current params

update_bg_tile:
	* special case: title screen
	cmp.w	#0x96,d7
	jne		0f
	cmp.b	#0xE8,d0
	jne		0f
	cmp.b	#7,d1
	jne		0f
	* skip all this crap altogether, blit the big pic
	jra		blit_title_pic
0:
	* now convert address to GnG layout. The screen size is the same
	* and all routines work, so let's not rewrite everything
	* there's this damn layout by quadrant that we eliminate that way
	lea	dd2gng_table,a1
	move.w	(a1,d7.w),d7
	
update_bg_tile_gng:
	moveq	#0,d2			| mask up to 255
	move.b	d0,d2			| tile code
	moveq	#0,d3
	move.b	d1,d3			| CLUT & tile code & flags

	move.w	d3,d4
	and.b	#7,d4
	lsl.w	#8,d4
	add.w	d4,d2			| full tile code

	* compute address
	
	move.w	d7,d0
	lsr.w	#5,d0	| divide by 0x20
	add.w	d0,d0	| 16 pixels
	add.w 	x_offset,d0		| add corkscrew makeup offset

	move.w	d7,d1
	subq.w	#1,d1		| first row is not shown with y scroll = 0
	and.w	#0x1F,d1	| modulus 0x20
	tst.b	must_mirror_y_tiles
	jeq		666f
	cmp.w	#0x10,d1
	scs		d6			| repeat tile draw if Y tile  < 0x10
	jra		667f
666:
	* full horizontal level: don't draw anything above tile 0x10, don't mirror
	sf		d6
*	cmp.w	#0x10,d1
*	jcs		667f
*	* do nothing, this tile will never be shown
*	rts
667:
	* updating bitplanes
	.if	BG_SCREEN_PLANE_SIZE>0x7FFF
	move.l	#BG_SCREEN_PLANE_SIZE,d5
	.else
	move.w	#BG_SCREEN_PLANE_SIZE,d5
	.endif
	
	move.l		playfield_drawed_screen_ptr,a1
	.ifeq	OPT_ENABLE_DOUBLE_BUFFERING
	.else 
	* double buffering
	move.l		playfield_displayed_screen_ptr,a4
	.endif
	
	move.w	#NB_BG_PLANES-1,d4   | needed even if no tile
	lea		mulBG_NB_BYTES_PER_ROW_table,A2
	.ifdef	NO68020
	add.w	d1,d1
	move.w	(a2,d1.w),d1
	.else
	move.w	(a2,d1.w*2),d1
	.endif
	lsl.w	#4,d1	| 16 pixels
	add.w	d1,d0
	add.w	d0,a1
	.ifeq	OPT_ENABLE_DOUBLE_BUFFERING
	.else 
	* double buffering
	add.w	d0,a4
	.endif

	lea		background_restore_buffer,a3
	add.w	d0,a3

	
	*cmp.b	#0x20,d2
	*jeq		11f				| optim: blank tile
	move.l		bg_tile_character_table,d0
	jeq		100f			| no context loaded: out
	move.l	d0,a0
	.ifdef	NO68020
	add.w	d2,d2
	add.w	d2,d2	
	move.l	(a0,d2.w),d0		| tile pointer
	.else
	move.l	(a0,d2.w*4),d0		| tile pointer
	.endif
	.ifdef	RELEASE
	jeq		11f					| clear tile, no error (release)
	.else
	jne		12f
	move.w	d7,-(a7)
	add.w	#BG_SCREEN_TILE_ADDRESS,d7
	.ifdef	NO68020
	lsr.w	#2,d2
	.endif
	*COLOR0_FLASH	0xF0F
	move.w	(a7)+,d7
	jra		11f
12:
	.endif
	move.l	d0,a2
	move.w	d3,d1		| save attributes
	*lsr.w	#4,d1
	*and.w	#3,d1		| mirror/flip
	moveq	#0,d1		| ATM no mirror no flip
	
	lsr.w	#3,d3		| tile_color = (attr >> 3) & 0x7
	and.w	#0x7,d3
	.ifdef	NO68020
	add.w	d3,d3
	add.w	d3,d3
	move.l	(a2,d3.w),d0			| pointer on tile bitplanes for that CLUT
	.else
	move.l	(a2,d3.w*4),d0			| pointer on tile bitplanes for that CLUT	
	.endif
	.ifdef	RELEASE
	jeq		11f						| not necessarily a problem
	.else
	jne		12f
	move.w	d7,-(a7)
	add.w	#BG_SCREEN_TILE_ADDRESS,d7
	lsr.w	#2,d2
	lsr.w	#2,d3
	*COLOR0_FLASH	0xFF0
	move.w	(a7)+,d7
	jra		11f
	.endif
12:
	move.l	d0,a2					| pointer on bitplanes


	lea		mirror_jump_table,a0
	.ifdef	NO68020
	add.w	d1,d1
	add.w	d1,d1
	move.l	(a0,d1.w),a0
	.else
	move.l	(a0,d1.w*4),a0
	.endif
	
	* we wait just in case a blitter operation is in progress
	* disabled ATM it seems that bg layout is widely static
	*lea		_custom,a5
	*REALLY_WAIT_BLIT
	tst.b 	d6
	jeq		0f
	movem.l	d0-D3/a0-a6,-(a7)
	jsr		(a0)
	* lower part too
	movem.l	(a7)+,d0-D3/a0-a6
	move.w	#2*BG_SCREEN_PLANE_SIZE/3,d6
	add.w	d6,a1
	add.w	d6,a3
	.ifne	OPT_ENABLE_DOUBLE_BUFFERING
	add.w	d6,a4
	.endif
	move.w	#NB_BG_PLANES-1,d4
0:
	jmp		(a0)

standard_tile16:

	* just copy

4:
	move.l	(a2)+,d0		| next plane
	jeq		5f
	move.l	d0,a0
	.set	offset,0
	.rept	16
	move.w	(a0)+,d0
	COPY_TILE16_PLANE_ROW
	.set	offset,offset+BG_NB_BYTES_PER_ROW
	.endr
41:
	TILE16_NEXT_PLANE
	dbf		d4,4b
	
100:
	rts
5:
	CLEAR_TILE16_PLANE
	jra		41b


flipped_tile16:	
4:
	move.l	(a2)+,d0		| next plane
	jeq		5f
	move.l	d0,a0
	.set	offset,8*BG_NB_BYTES_PER_ROW
	.rept	16
	.set	offset,offset-BG_NB_BYTES_PER_ROW
	move.w	(a0)+,d0
	COPY_TILE16_PLANE_ROW
	.endr
41:
	TILE16_NEXT_PLANE
	dbf		d4,4b
	
0:
	rts
5:
	CLEAR_TILE16_PLANE
	jra		41b

	
mirror_tile16:
	move.l	a5,-(a7)
	lea		mirror_table,a5
	.ifdef	MC68020
	moveq	#0,d1
	.endif
4:
	move.l	(a2)+,d0		| next plane
	jeq		5f
	move.l	d0,a0
	.set	offset,0
	.rept	16
	.ifdef	MC68020
	move.w	(a0)+,d1
	move.w	(a5,d1.l*2),d0	| mirror
	.else
	moveq	#0,d1	
	move.w	(a0)+,d1
	add.l	d1,d1
	move.w	(a5,d1.l),d0	| mirror
	.endif
	COPY_TILE16_PLANE_ROW

	.set	offset,offset+BG_NB_BYTES_PER_ROW
	.endr
41:
	TILE16_NEXT_PLANE
	dbf		d4,4b
	move.l	(a7)+,a5
	rts

5:
	CLEAR_TILE16_PLANE
	jra		41b
	
mirror_flipped_tile16:
	move.l	a5,-(a7)
	lea		mirror_table,a5
	.ifdef	MC68020
	moveq	#0,d1
	.endif
4:
	move.l	(a2)+,d0		| next plane
	jeq		5f
	move.l	d0,a0
	.set	offset,8*BG_NB_BYTES_PER_ROW
	.rept	16
	.set	offset,offset-BG_NB_BYTES_PER_ROW
	.ifdef	MC68020
	move.w	(a0)+,d1
	move.w	(a5,d1.l*2),d0	| mirror
	.else
	moveq	#0,d1	
	move.w	(a0)+,d1
	add.l	d1,d1
	move.w	(a5,d1.l),d0	| mirror
	.endif
	COPY_TILE16_PLANE_ROW
	.endr
41:
	TILE16_NEXT_PLANE
	dbf		d4,4b
	move.l	(a7)+,a5
	rts

5:
	CLEAR_TILE16_PLANE
	jra		41b

	* clear tile

11:
111:
	CLEAR_TILE16_PLANE
	TILE16_NEXT_PLANE
	dbf		d4,111b
2:
	rts

mirror_jump_table:
	.long	standard_tile16
	.long	mirror_tile16
	.long	flipped_tile16
	.long	mirror_flipped_tile16
	
	
cache_fg_tiles_address:
	moveq	#0,d7
	lea		fg_tile_address_table,a0
0:
	jbsr	compute_fg_tile_xy

	move.b	d0,(a0)+		| store offset
	move.b	d1,(a0)+		| store offset

	addq.w	#2,d7
	cmp.w	#0x800,d7
	jne		0b
	rts


* < D7: 0-0x800 (even)
* > D0/D1: coords 
compute_fg_tile_xy:
	moveq	#0,d0
	move.w	d7,d6
	lsr.w	#1,d6
	move.b	d6,d0
	
	and.b	#0x1F,d0	| x
	move.w	d6,d1
	lsr.w	#5,d1		| Y
	subq	#1,d1		| 1 first row isn't visible
	lsl.w	#3,d1		| times 8
	rts

*compute_tile_xy_portrait:
*	moveq	#0,d0
*	moveq	#0,d1
*	move.w	d7,d1
*	lsr.w	#5,d7		| this is X
*	neg.w	d7
*	add.w	#32,d7
*	and.w	#0x1F,d1	| this is Y
*	*addq.w	#2,d1
*
*	move.b	d7,d0		| this is X
*	lsl.b	#3,d1		| Y times 8
*	rts




* < D7: 0-0x800 offset (even!)
* < D0: tile code
* < D1: tile attribute

update_fg_tile:
	* if < 0x40 bail out as not visible
	cmp.w	#0x40,d7
	jcc		0f
	rts

0:

	moveq	#0,d2
	move.b	d0,d2	| code
	move.b	d1,d3	| attribute + tile msbits
	and.w	#0x7,d3
	lsl.w	#8,d3
	add.w	d3,d2	| extended tile code
	and.w	#0x3FF,d2	| else can go above 0x3FF, there's a stray bit
	moveq	#0,d3
	move.b	d1,d3	| attribute + tile msbits
	lsr.b	#5,d3	| clut
	

	lea		fg_tile_address_table,a1
	move.w	(a1,d7.w),d0
	moveq	#0,d1
	move.b	d0,d1
	rol.w	#8,d0
	and.w	#0xFF,d0

	
	* select which destination sprites (0-3)
	move.w	d0,d4
	lea		hw_sprite_pointers,a1
	and.w	#0xF8,d4		| divide by 8
							| then multiply by 8 (sprite go by pairs)
	lea	(a1,d4.w),a1

	
	and.w	#0x7,d0		| dest X offset
	lsl.w	#4,d1		| dest Y offset (8*2 pixels per row)
	add.w	d0,d1
	add.w	#0x10,d1	| skip control word
	
	* get 2 pointers for 2 attached sprites
	move.l	(a1)+,a2
	move.l	(a1),a1
	exg		a1,a2
	* add offset to destination
	
	add.w	d1,a2
	add.w	d1,a1
	
	* now get source data
	move.l		fg_tile_character_table,a0
	.ifndef	RELEASE
	cmp.l	#0,a0
	jne		0f
	BREAKPOINT	"no foreground graphics loaded"
0:
	.endif
	* updating bitplanes

	.ifdef	MC68020
	move.l	(a0,d2.l*4),d0		| tile pointer as LONG!
	.else
	add.w	d2,d2
	add.w	d2,d2	
	move.l	(a0,d2.l),d0		| tile pointer as LONG!
	.endif
	
	.ifdef	RELEASE
	jeq		11f 	| can happen when tile code is read when screen is being erased	
	.else
	jne		12f
	.ifndef	MC68020
	lsr.w	#2,d2
	.endif
	add.w	#FG_SCREEN_TILE_ADDRESS,d7
	**COLOR0_FLASH	0x00F
	*BREAKPOINT	"unregistered game tile (in D2, at address D7)"	

	jra		11f
	.endif
12:
	move.l	d0,a4
	.ifdef	MC68020
	move.l	(a4,d3.w*4),d0	| get proper clut
	.else
	add.w	d3,d3
	add.w	d3,d3	
	move.l	(a4,d3.w),d0	| get proper clut
	.endif
	jeq		11f
	
	
	move.l	d0,a4		| directly pointer on tile bitplanes
	
	.macro	NEXT_SOURCE_PLANE
4:
	move.l	(a4)+,d0		| next plane
	jne		5f
	move.l	#empty_row,d0
5:	
	move.l	d0,a0
	.endm
	
standard_tile:
	* first plane: first sprite
	NEXT_SOURCE_PLANE
	.set	offset,0
	.rept	8
	move.b	(a0)+,d0
	move.b	d0,(offset,a1)
	.set	offset,offset+16
	.endr
	* second plane: first sprite, with a 8 offset
	NEXT_SOURCE_PLANE
	.set	offset,8
	.rept	8
	move.b	(a0)+,d0
	move.b	d0,(offset,a1)
	.set	offset,offset+16
	.endr
	* third plane: second sprite
	NEXT_SOURCE_PLANE
	.set	offset,0
	.rept	8
	move.b	(a0)+,d0
	move.b	d0,(offset,a2)
	.set	offset,offset+16
	.endr
	* second plane: second sprite, with a 8 offset
	NEXT_SOURCE_PLANE
	.set	offset,8
	.rept	8
	move.b	(a0)+,d0
	move.b	d0,(offset,a2)
	.set	offset,offset+16
	.endr

11:
	rts


empty_row:
	.skip	8
		
blit_title_pic:
	lea		_custom,a5
	lea		sprite_table_buffer,a0
	move.w	(a0)+,d0				| nb bitplanes
	moveq	#2,d1
	lsl.w	d0,d1
	add.w	d1,a0
	* now we point to the dimensions
	move.w	(a0)+,d2
	move.w	(a0)+,d4
	* now A0 points to the list of planes
	move.w	sprite_table_buffer,d3	| nb bitplanes
	move.w	#32,d0
	move.w	#24,d1
	moveq	#0,d5
	move.l	playfield_drawed_screen_ptr,a1
	jbsr	blit_planes_any_internal_no_cookie_cut
	rts

	
	rts
	

* < d0.w: x
* < d1.w: y
* < a1: sprite pos table (depending on height)
* > d0.L: control word
store_sprite_pos:
	tst.w	d1
	jmi	0f
	cmp.w	#Y_MAX,d1
	jcc	0f

    move.l  a0,-(a7)

    lea	HW_SpriteXTable(pc),a0
	
	.ifndef	MC68020
    add.w	d0,d0
    add.w	d0,d0
    move.l	(a0,d0.w),d0
	move.w	d1,-(a7)
    add.w	d1,d1
    add.w	d1,d1
    or.l	(a1,d1.w),d0
	move.w	(a7)+,d1
	.else
    move.l	(a0,d0.w*4),d0
    or.l	(a1,d1.w*4),d0	
	.endc
    move.l  (a7)+,a0
    rts
0:
	moveq	#0,d0
	rts
	



HW_SpriteXTable:
	.set	reptn,0
	.rept 320
	.set	x,reptn+0x80
	.set reptn,reptn+1
    .byte  0,x>>1,0,x&1
  .endr

	.macro DEF_HW_SPRITE_Y_TABLE	height
HW_SpriteYTable_\height:
  .set	reptn,0
  .rept 288
	.set	ys,reptn+0x1c
	.set	ye,ys+\height
    .byte  ys&255, 0, ye&255, ((ys>>6)&4)+((ye>>7)&2)
	.set	reptn,reptn+1
  .endr
	.endm

	DEF_HW_SPRITE_Y_TABLE	256


set_bobs_bitplanes:
	movem.l	a0-a1/d0-d2,-(a7)
	
	* set bitplanes
	moveq	#0,d0
	move.w	game_scroll_y,d0
	lea		mulBG_NB_BYTES_PER_ROW_table,a2
	.ifdef	MC68020
	move.w	(a2,d0.w*2),d0		| compute Y offset
	.else
	add.w	d0,d0
	move.w	(a2,d0.w),d0		| compute Y offset
	.endif
1:	
	move.w	host_scroll_x,d2
	and.w	#0x0FF,d2			| wraps at 0x100!

	lea		scroll_table,a2
	.ifdef	MC68020
	lea		(a2,d2.w*4),a2
	.else
	add.w	d2,d2
	add.w	d2,d2
	add.w	d2,a2
	.endif
	
	move.w	(a2)+,fine_x_scroll_value
	move.w	host_scroll_x,d2
	lsr.w	#6,d2
	lsl.w	#3,d2
	add.w	d2,d0
	
	
    moveq #NB_PLAYFIELD_PLANES-1,d1
 	move.l	#BG_SCREEN_PLANE_SIZE,d2
	.ifndef	RELEASE
	* quick check just in case someone uses that with plane size > 0x7FFF
	jpl		10f
	BREAKPOINT	"negative plane size!"
10:
	.endif
2:
    move.l	playfield_displayed_screen_ptr(pc),a0
	
	add.l	d0,a0		| X/Y scroll offset (long!)
	move.l	a0,d0		| first bitplane screen pointer
 	lea	bobs_bitplanes+2,a0
1:
    swap d0
    move.w d0,(a0)
    swap d0
    move.w d0,(4,a0)    
    addq.w  #8,a0
    add.l d2,d0
    dbf d1,1b
	movem.l	(a7)+,a0-a1/d0-d2
    rts

scroll_table:
	* generated by python script
	.ifne	OPT_AGA_MODE
	.include	"scroll_table_64.68k"
	.else
	.include	"scroll_table_16.68k"
	.endif

osd_debug_hook:
	rts
	
	

osd_read_p1_inputs:
	move.b	 player_1_controls,d0
	rts


osd_read_p2_inputs:
	st.B	d0
	rts
	


	
	.ifne	OPT_ENABLE_LOGGING
purge_tile_log_data:
	movem.l	d0-a6,-(a7)
	* reset logged tiles
	lea	bg_tile_log_table,a0
0:
	clr.l	(a0)+
	cmp.l	#bg_tile_log_table_end,A0
	jne	0b
	lea	fg_tile_log_table,a0
0:
	clr.l	(a0)+
	cmp.l	#fg_tile_log_table_end,A0
	jne	0b


	movem.l	(a7)+,d0-a6
	rts
purge_sprite_log_data:
	movem.l	d0-a6,-(a7)
	lea		sprite_log_table,a0
	lea		sprite_log_table_end,a1
0:
	clr.l (a0)+
	cmp.l	a0,a1
	jne		0b
	movem.l	(a7)+,d0-a6
	rts
	.endif

	
* < D1: previous state
update_player_1_controls:
	moveq	#-1,d0

	lea		keyboard_table(pc),a0

	tst.b	(0x4C,a0)		| "up" key
	beq.b	0f
	bclr	#BIT_UP,d0
0:
	tst.b	(0x4D,a0)		| "down" key
	beq.b	0f
	bclr	#BIT_DOWN,d0
0:
	tst.b	(0x4F,a0)		| "<-" key
	beq.b	0f
	bclr	#BIT_LEFT,d0
0:
	tst.b	(0x4E,a0)		| "->" key
	beq.b	0f
	bclr	#BIT_RIGHT,d0
0:
	tst.b	(0x63,a0)		| "ctrl" key
	beq.b	0f
	bclr	#BIT_KICK,d0
0:
	tst.b	(0x64,a0)		| left "alt" key
	beq.b	0f
	bclr	#BIT_JUMP,d0
0:
	tst.b	(1,a0)		| "1" key like in MAME
	beq.b	0f
	st.b	detect_controllers
	bclr	#BIT_START_1P,d0
0:	
	tst.b	(2,a0)		| "2" key like in MAME
	beq.b	0f
	st.b	detect_controllers
	bclr	#BIT_START_2P,d0
0:	

	* directions + fire
	move.l	joypad_1_state(pc),d1
	jbsr	decode_joypad_controls
	btst	#JPB_BTN_GRN,d1
	jeq		0f
	bclr	#BIT_PUNCH_1P,d0
0:
	move.b	d0,player_1_controls

	rts
	
decode_joypad_controls:
	btst	#JPB_BTN_UP,d1
	beq.b	0f
	bclr	#BIT_UP,d0
0:
	btst	#JPB_BTN_DOWN,d1
	beq.b	0f
	bclr	#BIT_DOWN,d0
0:
	btst	#JPB_BTN_LEFT,d1
	beq.b	0f
	bclr	#BIT_LEFT,d0
0:
	btst	#JPB_BTN_RIGHT,d1
	beq.b	0f
	bclr	#BIT_RIGHT,d0
0:
	btst	#JPB_BTN_RED,d1
	beq.b	0f
	bclr	#BIT_KICK,d0
0:
	btst	#JPB_BTN_BLU,d1
	beq.b	0f
	bclr	#BIT_JUMP,d0
0:
	rts
	

osd_read_dsw1:
	* actual dipswitches
	move.b	dip_switches_1,d0	| what MAME returns by default: demo sounds on. ~0x60: service mode
	rts

osd_read_dsw2:
	* actual dipswitches
	move.b	dip_switches_2,d0	| what MAME returns by default
	rts
	


	

	

level2_interrupt:
	jbsr		handle_keyboard
	move.w	#8,_custom+intreq
	rte
	
	


*	uint8_t const attr = m_fgvideoram[tile_index];
*	tileinfo.set(0,
*			m_fgvideoram[tile_index | 1] | ((attr & 0x07) << 8),
*			attr >> 5,
*			0);

	.ifne	OPT_ENABLE_LOGGING
log_used_fg_tiles:
	* scan the whole screen, see what was updated
	* main screen

	GET_MEMORY_START_IN_A6
	lea		(FG_SCREEN_TILE_ADDRESS,a6),a5

	lea		fg_tile_log_table,a0
	move	#(1<<FG_TILE_NB_CLUTS_POW)-1,d4		| clut mask
	move	#FG_TILE_NB_CLUTS_POW,d5		| nb clut pow
	move.w	#0x7FE,d7
0:
	moveq	#0,d1
	moveq	#0,d0
	move.b	(a5,d7.w),d1	| tile attribute
	move.b	(1,a5,d7.w),d0	| tile code

	moveq	#0,d2
	move.b	d0,d2	| code
	move.b	d1,d3	| attribute + tile msbits
	and.w	#0x7,d3
	lsl.w	#8,d3
	add.w	d3,d2	| extended tile code
	and.w	#0x3FF,d2	| we have to mask it!
	moveq	#0,d3
	move.b	d1,d3	| attribute + tile msbits
	lsr.b	#5,d3
	
	lsl.w	d5,d2
	add.w	d3,d2
	st.b	(a0,d2.w)
20:
	subq	#2,d7
	jpl		0b
	rts
	
log_used_bg_tiles:
	* scan the whole screen, see what was updated
	* main screen

	GET_MEMORY_START_IN_A6
	lea		(BG_SCREEN_TILE_ADDRESS,a6),a5
	lea		bg_tile_log_table,a0
	move	#(1<<BG_TILE_NB_CLUTS_POW)-1,d4		| clut mask
	move	#BG_TILE_NB_CLUTS_POW,d5		| nb clut pow

	move.w	#0x7FE,d7
0:
	moveq	#0,d1
	moveq	#0,d0
	move.b	(a5,d7.w),d1	| tile attribute
	move.b	(1,a5,d7.w),d0	| tile code

	moveq	#0,d2
	moveq	#0,d3
	move.b	d0,d2	| code
	move.b	d1,d3	| attribute + tile msbits
	and.w	#0x7,d3
	lsl.w	#8,d3
	add.w	d3,d2	| extended tile code
	moveq	#0,d3
	move.b	d1,d3	| attribute + tile msbits
	lsr.b	#3,d3
	and.b	#7,d3	| tile_color = (attr >> 3) & 0x7


	lsl.l	d5,d2			| tile code * NB_CLUTS (long!)
	add.l	d3,d2			| add clut
	st.b	(a0,d2.l)
20:
	subq	#2,d7
	jpl		0b
	rts
	
* sprite_log, log_sprites
log_used_sprites:

	* scan the whole screen, see what was updated
	* main screen
	
	GET_MEMORY_START_IN_A6
	lea		(SPRITE_ADDRESS,a6),a5
	lea	sprite_log_table,a0
	moveq	#0,d7
0:
	cmp.b	#0xF8,(TARGET_SPRITE_Y,a5,d7.w)
	jeq		1f			| not active
	moveq	#0,d2
	moveq	#0,d1
	moveq	#0,d0
	move.b	(TARGET_SPRITE_CODE,a5,d7.w),d0
	move.b	(TARGET_SPRITE_ATTRIBUTES,a5,d7.w),d1
	move.b	d1,d2
	* extended tile code
	lsl.w	#2,d2
	and.w	#0x300,d2
	add.w	d2,d0
	lsr.b	#4,d1
	and.w	#SPRITE_NB_CLUTS-1,d1
	
	lsl.l	#SPRITE_NB_CLUTS_POW,d0			| sprite code * NB_CLUTS (long!)
	add.l	d1,d0			| add clut

	st.b	(a0,d0.l)
1:
	addq	#TARGET_SPRITE_SIZEOF,d7
	cmp.w	#NB_TARGET_SPRITES*TARGET_SPRITE_SIZEOF,d7
	jne		0b
	rts
	.endif
	
redraw_bg_tiles:
	movem.l	d0-a6,-(a7)
	jbsr 	force_all_screen_redraw
	movem.l	(a7)+,d0-a6
	rts
	
skip_level:
	movem.l	d0-a6,-(a7)
	GET_MEMORY_START_IN_A6
	movem.l	(a7)+,d0-a6
	rts
	
	
handle_keyboard:
	movem.l	D0/A0/A5,-(a7)
	LEA	0x00BFD000,A5
	MOVEQ	#0x08,D0
	AND.B	0x1D01(A5),D0
	jeq		1f
	MOVE.B	0x1C01(A5),D0
	NOT.B	D0
	ROR.B	#1,D0		| raw key code here
  
	CLR.B	0x1C01(A5)
  
    lea keyboard_table(pc),a0
    bclr    #7,d0
    seq (a0,d0.w)       | updates keyboard table
    jne   2f     | we don't care about key release
	

	cmp.b	#5,d0	| "5" key like in MAME
	bne.b	0f
	st.b	coin1_requested
0:
	cmp.b	#6,d0	| "5" key like in MAME
	bne.b	0f
	st.b	coin2_requested
0:

    cmp.b   #0x19,d0	| "P" key
    bne.b   0f

    bsr	toggle_pause
0:

	* last life, time=0, direct game over
	cmp.b	#69,d0	| F8 key: set time at 0
	bne.b	0f
	jbsr	lose_all_lives
0:


	* cheat keys are always active in dev mode
	.ifdef	RELEASE
	btst	#4,cheat_flags+3
	jeq		10f
	.endif
	* cheat keys


	cmp.b	#0x50,d0	| F1 key: toggle invincible
	bne.b	0f
	st.b	cheat_used
	not.b	invincible_flag
	COLOR0_FLASH	0x0FF
	
0:
	cmp.b	#0x51,d0	| F2 key: skip level
	bne.b	0f
	st.b	cheat_used
	jbsr	skip_level
	COLOR0_FLASH	0x0FF
	
0:
	cmp.b	#0x52,d0	| F3 key: 
	bne.b	0f
	st.b	cheat_used

	
0:

	cmp.b	#0x53,d0	| F4 key: 
	bne.b	0f
	st.b	cheat_used
	COLOR0_FLASH	0x0FF
0:
	cmp.b	#0x54,d0	| F5 key
	bne.b	0f
	st.b	cheat_used
	COLOR0_FLASH	0x0FF
	jbsr	add_to_score
0:

10:
	.ifndef	RELEASE
	cmp.b	#34,d0
	bne		0f
	* 'D': dump all logging buffers to data dir
	jbsr	osd_dump_logs
0:

	
	cmp.b	#0x55,d0	| F6 key: debug params
	bne.b	0f
	COLOR0_FLASH	0x0FF
	jbsr	redraw_bg_tiles
0:
	cmp.b	#0x56,d0	| F7 key: debug params
	bne.b	0f
	eor.b		#1,osd_debug_active
0:
	cmp.b	#0x58,d0	| F9 key crashes game (restarts whdload)
	bne.b	0f
	illegal
0:

	.endif

	cmp.b	_keyexit,d0	| "ESC" key or whdload quitkey
	bne.b	2f
	BSET	#0x06,0x1E01(A5)
	moveq	#2,d0
	bsr	beamdelay
	BCLR	#0x06,0x1E01(A5)	| acknowledge key
	bra		quit_to_os
2:
	BSET	#0x06,0x1E01(A5)
	moveq	#2,d0
	bsr	beamdelay
	BCLR	#0x06,0x1E01(A5)	| acknowledge key

1:
	movem.l	(a7)+,d0/a0/a5
	rts
	
toggle_pause:
	* pause only within game
	jbsr		is_game_playing
	*beq.b	0f
	eor.b   #1,pause_flag
0:
	rts

	

    
* < D0: numbers of vertical positions to wait
beamdelay:
0:
	move.w  d0,-(a7)
    move.b	0xdff006,d0	| VPOS
1:
	cmp.b	0xdff006,d0
	beq.s	1b
	move.w	(a7)+,d0
	dbf	d0,0b
	rts

	
	MUL_TABLE	BG_NB_BYTES_PER_ROW,BG_NB_LINES
	MUL_TABLE	FG_NB_BYTES_PER_ROW,FG_NB_LINES

	.align	4		| leave this long word alignment
program_args:	ds.l	64,0
program_args_end:
	.long	0		| add a longword else it overwrites the read args string in kick 1.3!
	.align	4
read_args_string:
	.byte	read_args_string_end-read_args_string
	.ascii	"CHEATKEYS/S,FIVELIVES/S,FAST/S"
read_args_string_end:
	.align	2

* < A0: highscore buffer
osd_read_high_scores:
	OSD_ENTER
	movem.l	d0-d7/a0-a6,-(a7)
	GET_MEMORY_START_IN_A6
	**lea	(high_score_table_1518,a6),a0
	move.l	_resload,d0
	beq.b	0f
	move.l	d0,a2
	move.l	a0,a1
	bsr		get_hiscore_name
	move.l	a1,-(a7)
 	jsr		resload_GetFileSize(a2)		
	move.l	(a7)+,a1
	tst.l	d0
	beq.b	1f
	bsr		get_hiscore_name
	jsr		resload_LoadFile(a2)	
	bra.b	1f
0:
	tst.b	highscore_loaded
	beq.b	1f

	* from DOS: just copy buffer
	lea		high_score_buffer,a1
	move.w	#SCORE_FILE_SIZE-1,d0
0:
	move.b	(a1)+,(a0)+
	dbf		d0,0b
1:
	**lea	(high_score_table_1518,a6),a0
	move.w	(a0),d0		| offset for highest score
	lea		(a6,d0.w),a0
	* also update copy (for top screen display)
	**lea	(high_score_00d0,a6),a1
	move.l	(a0),(a1)
	movem.l	(a7)+,d0-d7/a0-a6
	OSD_EXIT
	rts
	
* < A0: highscore buffer
osd_write_high_scores:
	OSD_ENTER
	movem.l	d0-d7/a0-a6,-(a7)
	.ifdef	RELEASE
	tst.b	cheat_used		| don't save score if cheat on
	bne.b	2f
	.endif
	GET_MEMORY_START_IN_A6
	**lea	(high_score_table_1518,a6),a0
	
	move.l	_resload,d0
	bne.b	1f
	* DOS
	* first just copy buffer as contiguous 
	lea		high_score_buffer,a1
	move.w	#SCORE_FILE_SIZE-1,d0
0:
	move.b	(a0)+,(a1)+
	dbf		d0,0b
	st.b	highscore_needs_saving
	jra		2f
1:
	* whdload
	move.l	a0,a1
	move.l	d0,a2
	move.l	#SCORE_FILE_SIZE,d0
	bsr		get_hiscore_name
	jsr		resload_SaveFile(a2)
2:

	movem.l	(a7)+,d0-d7/a0-a6
	OSD_EXIT
	rts

	
get_hiscore_name:
    lea normal_hiscorename,a0
	rts
	
load_highscores:
    move.l  _resload,d0
    bne.b   1f

	bsr.b		get_hiscore_name
    move.l  _dosbase,a6
    move.l  a0,d1
    move.l  #1005,d2
    jsr     (_LVOOpen,a6)
    move.l  d0,d1
    beq.b   1f
    move.l  d1,d4
    move.l  #SCORE_FILE_SIZE,d3
    move.l  #high_score_buffer,d2
    jsr (_LVORead,a6)
    move.l  d4,d1
    jsr (_LVOClose,a6)   
	st.b	highscore_loaded
1:

    rts

save_highscores:
	tst.l	_resload
	bne.b	1f
    tst.b   highscore_needs_saving
    beq.b   1f
    move.l  _dosbase,a6
	bsr.b		get_hiscore_name
    move.l  a0,d1
    move.l  #1006,d2
    jsr     (_LVOOpen,a6)
    move.l  d0,d1
    beq.b   1f
    move.l  d1,d4
    move.l  #SCORE_FILE_SIZE,d3
    move.l  #high_score_buffer,d2
    jsr (_LVOWrite,a6)
    move.l  d4,d1
    jsr (_LVOClose,a6)   
1:	
    rts
    
	
osd_music_stop:
*	movem.l	d0/a0/a6,-(a7)
*	lea		_custom,a6
*	move.w	#3,d0
*	jbsr	_mt_stopfx
*	movem.l	(a7)+,d0/a0/a6

	
	tst.b	music_playing
	jne		force_sound_stop
	rts

force_sound_stop:
	OSD_ENTER
	movem.l	d0-d1/a0/a6,-(a7)
	lea		_custom,a6
	move.b	#-1,music_track_start_number
    clr.w   music_tick   | not playing anymore
	clr.b	music_playing
	clr.l	looped_sound_enabled

    jsr		_mt_end

	movem.l	(a7)+,d0-d1/a0/a6
	OSD_EXIT
	rts
	
* < D0.B sound index
osd_sound_start:
	OSD_ENTER
	movem.l	d0/d1/d2/a0/a1/a6,-(a7)
	lea		_custom,a6
	


	moveq	#0,d2
	
	and.w	#0xFF,d0
	lsl.w	#3,d0
	lea		sound_table,a0


	move.w	(a0,d0.w),d1	| sound type
	jeq	11f		| no sound
	cmp.w	#3,d1
	jeq	10f			| mute for now
2:
	cmp.w	#1,d1
	jne	4f		| music module
	move.w	(2,a0,d0.w),d1
	move.l	(4,a0,d0.w),a0
	lea		_custom,a6
	tst		d1
	jeq	3f
	
	* looped sound
	moveq	#0,d0
	move.b	(10,a0),d0		| channel

	lea		looped_sound_enabled,a1
	
	* sound stop
	clr.b	(a1,d0.w)
	movem.l	d0/a0,-(a7)
	jbsr	_mt_stopfx
	movem.l	(a7)+,d0/a0
	tst.b	d2
	jne		10f		| sound stop requested: done
2:
	* now that prev loop is stopped, play the next one
	st.b	(a1,d0.w)
	jbsr		_mt_loopfx
	jra	10f
3:
	jbsr		_mt_playfx
10:
	movem.l	(a7)+,d0/d1/d2/a0/a1/a6
	OSD_EXIT
	rts
11:
	.ifndef	RELEASE
	lsr.w	#3,d0
	move.w	d0,d2
	BREAKPOINT	"unknown sound (in d2)"
	.endif
	jra		10b
12:
	* stop all sounds
	jbsr	_mt_end
	jra		10b
	
	* music
4:


	jbsr	load_music_if_needed
	
	* don't play if already playing
	* (music_tick value is not important for looped tunes
	* as long as it's not zero)


	* here we allow music to override another looping music
	*tst.w	music_tick
	*bne.b	10b
	* play the proper module pattern
	* load up the countdown if loop
		

    movem.l d0-a6,-(a7)
	bsr		force_sound_stop
    lea _custom,a6
 	movem.l	d0/a0,-(a7)
	
	move.w	(2,a0,d0.w),d1	| pattern number in .mod file
	lea		module_buffer,a0
	moveq	#0,d0
	move.w	d1,d0
    sub.l   a1,a1		| samples are in the module
    jsr _mt_init
	movem.l	(a7)+,d0/a0

    * set master volume a little less loud if needed
	move.b	(6,a0,d0.w),music_volume
	*move.b	(7,a0,d0.w),music_loops
	*move.w	(4,a0,d0.w),d2

	*move.w	d2,music_duration
	*move.w	d2,music_tick

    moveq	#0,d0
	move.b	music_volume,d0
    jsr	_mt_mastervol
	st.b	music_playing
    jsr _mt_start
5:
    movem.l (a7)+,d0-a6
	
6:
	jra	10b
no_tune:
	movem.l	(a7)+,d0/a0
	jra		5b
	
load_music_if_needed:
	movem.l	d0/a0/a1,-(a7)

	cmp.l	current_music_name,a0
	jeq		75f
	* stop current music if any
	jbsr	osd_music_stop
	
	move.l	a0,current_music_name
	lea		module_buffer,a1
	move.l	#BIGGEST_MUSIC_SIZE,d0
	jbsr	load_file
75:
	movem.l	(a7)+,d0/a0/a1
	rts
	
* all level modules have the same structure but in fact not atm...
* 0-9              stage music + boss
* 10               empty block in loop      
* 11               low time                 
* 12               death                    
* 13               MAP                     
* 14-15          game over                
* 16-17          Key         
* 
* (only last boss mod)             
* 16                bad ending
* 17-22           good ending
	

quit_to_os:
	tst.l	_resload
	bne.b	0f
	jbsr		restore_system
	* set SR to 0 from here, so we return to OS with SR=0
	* (else it kills the system pretty quickly)
	* it works as quit_to_os is called from an interrupt
	move.w	#0,SR
	move.l	old_stack,a7
	*jbsr		save_highscores
	moveq	#0,d0
	rts
0:
	pea	  TDREASON_OK
	move.l	_resload,-(a7)
	addq.l	#resload_Abort,(a7)
	rts




* < A0: filename
* > D0: size (decrunch supported)
get_file_size:
	tst.l	_resload
	jeq		0f
	movem.l	d1/a0-a2,-(a7)
	move.l	_resload,a2
	jbsr	(resload_GetFileSizeDec,a2)
	movem.l	(a7)+,d1/a0-a2
	rts
0:
	* unsupported
	BREAKPOINT	"non-whdload mode unsupported"
	rts


* zero all registers even 6809 stack pointer
* (some games use stack pointer manually for auto variables)
cpu_init:
	moveq	#0,d0
	moveq	#0,d1
	moveq	#0,d2
	moveq	#0,d3
	moveq	#0,d4
	moveq	#0,d6
	moveq	#0,d7
	rts	
	
	.ifndef	RELEASE
scrollx_text:
	.ascii	"Game ScrollX "
	.byte	0xff
hscrollx_text:
	.ascii	"Host ScrollX "
	.byte	0xff
scrolly_text:
	.ascii	"Game ScrollY "
	.byte	0xff	
last_x_offset_text:
	.ascii	"Last Xoffset "
	.byte	0xff
debug_1_text:
	.ascii	"User 1 "
	.byte	0xff
debug_2_text:
	.ascii	"User 2 "
	.byte	0xff
debug_3_text:
	.ascii	"User 3 "
	.byte	0xff


	.align	2
* < D0.W address of value to display (like this it is watched at each irq)
* < D1.W slot (0-3)
osd_display_value:
	movem.l	a0/d1,-(a7)
	lea		display_slots,a0
	and.w	#3,d1
	add.w	d1,d1
	add.w	d1,d1
	add.w	d1,a0
	st.b	(a0)
	move.w	d0,(2,a0)
	movem.l	(a7)+,a0/d1
	rts
	
display_slots:
	.long	0
	.long	0
	.long	0
	.long	0
	.endif
	
	.ifne	OPT_ENABLE_LOGGING

osd_get_last_known_pc:
	move.w	last_known_m6809_pc,d6
	cmp.w	#0xFFFF,d6
	jeq		0f
	move.w	last_declared_bank,d7
	rts
0:
	move.w	0x100,d6
	move.w	0x102,d7
	rts
	
	
* < D6: 0 disable, 1 enable, 2 reenable (restore state before disable)
* 2 is useful because you can 1) disable and 2) reenable
* if was not already enabled, reenable will do nothing
osd_cpu_logging_control:
	cmp.b	#2,d6
	jeq		1f
	* it's essential that we skip a second enable while active
	* or disable while inactive
	* else it kills the "reenable" feature, overwriting previous
	cmp.b	cpu_log_enable,d6
	jeq		2f		| enabled/disabled twice: skip
	* 0 or 1: save previous state	
	move.b	cpu_log_enable,cpu_log_prev_state
	move.b	d6,cpu_log_enable
	rts
1:
	* 2: reenable: put previous state, reenabling if needed
	move.b	cpu_log_prev_state,cpu_log_enable
2:
	rts
	
	.macro	CHECK_ZERO_MSW	reg
	swap	\reg
	tst		\reg
	jeq		0f
	move.w	(6,a7),d6
	swap	\reg
	BREAKPOINT		"\reg MSW is not zero, PC=check d6!"
0:
	swap	\reg
	.endm

	
osd_log_cpu:
	OSD_ENTER
	* first, check that registers don't have a wrong longword mask
	CHECK_ZERO_MSW	d1		| D
	CHECK_ZERO_MSW	d2		| X
	CHECK_ZERO_MSW	d3		| Y
	CHECK_ZERO_MSW	d4		| U
	CHECK_ZERO_MSW	d5		| S

*	check that stack is in RAM
*   we had to disable it because at some point the game uses
*   puls/pulu to read data
*	cmp.l	#0x3000,d5
*	jcs		0f
*	BREAKPOINT	"target stack is not in RAM"
*0:
	move.w	(4,a7),last_declared_bank
	move.w	(6,a7),last_known_m6809_pc
	
	move.w	last_known_m6809_pc,0x100
	move.w	last_declared_bank,0x102
	
	movem.l	d1/a6,-(a7)
	* check if cpu log is enabled
	tst.b	cpu_log_enable
	jeq		445f
	COLOR0_FLASH	0x0F0

	move.l	log_ptr,a6
	move.w	last_known_m6809_pc,(a6)+	| the PC
	move.w	last_declared_bank,(a6)+	| the PC
	rol.w	#8,d1
	move.b	d0,d1
	rol.w	#8,d1   | make D, make sure that not too many diffs
	move.w	d0,(a6)+
	move.w	d1,(a6)+
	move.w	d2,(a6)+
	move.w	d3,(a6)+
	move.w	d4,(a6)+
	move.w	#0xDEAD,(a6)+
	move.l	a6,log_ptr
	cmp.w	#0xCAFE,(a6)  | hitting the protection buffer
	jne		444f
	BREAKPOINT	"cpu log buffer full, dumping and exiting!"
	jbsr	osd_dump_logs
	illegal
444:

445:
	* check that bank and code match
	move.b	last_declared_bank+1,d1
	jmi	446f			| ignore
	cmp.b	current_rom_bank,d1
	jeq		446f
	move.w	last_known_m6809_pc,d1
	move.w	last_declared_bank,a6
	BREAKPOINT	"code/data bank mismatch, PC in D1, last declared bank in a6.W"
446:
	movem.l	(a7)+,a6/d1
	OSD_EXIT
	rts

osd_dump_logs:
	OSD_ENTER
	move.w	sr,-(a7)
	move.w	#0x2700,SR
	movem.l	d0-a6,-(a7)
	
	jbsr	save_cpu_log

	move.l	_resload,a2
	lea		fg_tile_log_table,a1
	lea		fg_tile_log_name(pc),a0
	move.l	#FG_TILE_LOG_LENGTH,d0
	jbsr	resload_SaveFile(a2)
	
	lea		bg_tile_log_table,a1
	lea		bg_tile_log_name(pc),a0
	move.l	#BG_TILE_LOG_LENGTH,d0
	jbsr	resload_SaveFile(a2)
	
	lea		sprite_log_table,a1
	lea		sprite_log_name(pc),a0
	move.l	#SPRITE_LOG_LENGTH,d0
	jbsr	resload_SaveFile(a2)
	
	GET_MEMORY_START_IN_A6
	lea		(SPRITE_ADDRESS,a6),a1
	lea		sprite_mem_name(pc),a0
	move.l	#SPRITE_BUFFER_SIZE,d0
	jbsr	resload_SaveFile(a2)
	
	
    movem.l (a7)+,d0-a6
	move.w	(a7)+,SR
	OSD_EXIT
	rts


save_cpu_log:
	move.l	_resload,a2
	lea		log_buffer,a1
	move.l	log_ptr,d0
	sub.l	a1,d0
	jeq		0f
	move.l	log_ptr,a0
	* add RAM & ROM base in the end
	move.l	a6,(a0)+
	move.l	#rom_base,(a0)+
	addq	#8,d0
	lea		cpu_log_name(pc),a0
	jbsr	resload_SaveFile(a2)
0:	
	rts


