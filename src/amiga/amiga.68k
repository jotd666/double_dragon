FG_TILE_FILE_MAX_SIZE = 0x8000
BG_TILE_FILE_MAX_SIZE = 0x14000
SPRITE_FILE_MAX_SIZE = 0x30000

	.if		OPT_CD32_VERSION==0
BIGGEST_MUSIC_SIZE = 385000
	.else
BIGGEST_MUSIC_SIZE = 96000
	.endif
	
SCORE_FILE_SIZE = 90

LOG_BUFFER_SIZE = 0x100000

FG_TILE_NB_CLUTS_POW = 3
FG_TILE_NB_CLUTS = 1<<FG_TILE_NB_CLUTS_POW
