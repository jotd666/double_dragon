memory_check_b7ed:
* start with WORK RAM 0000-1000
	GET_DP_ADDRESS	bank_switch_copy_3a     	| [$b7ed: ldu    bank_switch_copy_3a]
	MOVE_W_TO_REG	a0,d4                         	| [...]
	clr.w	d2                               	| [$b7ef: ldx    #$0000]
	move.w	#0xb8e5,d3                      	| [$b7f2: ldy    #$b8e5] random part of ROM as source (not zeroes!)
l_b7f6:
	move.b	#0x03,d1                        	| [$b7f6: ldb    #$03]
l_b7f8:
	moveq	#0,d6                            	| [...]
	move.b	d1,d6                           	| [...] as byte
	DO_EXTB	d6                             	| [...] with sign extension
	GET_REG_ADDRESS_FROM_REG	d6,d3         	| [$b7f8: lda    b,y]
	move.b	(a0),d0                         	| [...]
	GET_REG_ADDRESS	0,d2                   	| [$b7fa: sta    ,x]
	move.b	d0,(a0)                         	| [...]
	| [$b7fc: lda    ,x]
	move.b	(a0),d0                         	| [...]
	moveq	#0,d6                            	| [...]
	move.b	d1,d6                           	| [...] as byte
	DO_EXTB	d6                             	| [...] with sign extension
	GET_REG_ADDRESS_FROM_REG	d6,d3         	| [$b7fe: cmpa   b,y] compare to see if same value
	cmp.b	(a0),d0                          	| [...]
	jne	l_b810                             	| [$b800: bne    $b810]
	subq.b	#1,d1                           	| [$b802: decb]
	jpl	l_b7f8                             	| [$b803: bpl    $b7f8]
	addq.w	#0x1,d2                         	| [$b805: leax   $1,x]
	cmp.w	#fg_tiles_palette_1000,d2        	| [$b807: cmpx   #fg_tiles_palette_1000]
	jne	l_b7f6                             	| [$b80a: bne    $b7f6]
	move.b	#0x00,d1                        	| [$b80c: ldb    #$00] no RAM error
	jra	l_b812                             	| [$b80e: bra    $b812]
l_b810:
	move.b	#0x01,d1                        	| [$b810: ldb    #$01] RAM error
l_b812:
	move.b	#0x00,d0                        	| [$b812: lda    #$00]
	GET_DP_ADDRESS	bank_switch_copy_3a     	| [$b814: stu    bank_switch_copy_3a]
	MOVE_W_FROM_REG	d4,a0                         	| [...]
	jbsr	set_screen_orientation_fea1       	| [$b816: jsr    set_screen_orientation_fea1]
	jbsr	write_diagnostic_message_b8ea     	| [$b819: jsr    write_diagnostic_message_b8ea] "WORK RAM OK"
	OP_1_ON_DP_ADDRESS	clr,0x02             | [$b81c: clr    $02]
	OP_R_ON_DP_ADDRESS	move,bank_switch_copy_3a,d0| [$b81e: lda    bank_switch_copy_3a]
	and.b	#0x1f,d0                         	| [$b820: anda   #$1f]
	OP_W_ON_DP_ADDRESS	move,bank_switch_copy_3a,d0| [$b822: sta    bank_switch_copy_3a]
l_b824:
	OP_1_ON_DP_ADDRESS	clr,0x00             | [$b824: clr    $00] checksum for 2 banks (1 rom = 2 banks)
	OP_1_ON_DP_ADDRESS	clr,0x01             | [$b826: clr    $01]
* checksum of banks, loop 3 times (ROM 1-3 in diag screen, 2 banks per ROM)
l_b828:
	move.w	#bank_address_4000,d2           	| [$b828: ldx    #bank_address_4000]
	OP_R_ON_DP_ADDRESS	move,bank_switch_copy_3a,d0| [$b82b: lda    bank_switch_copy_3a]
	jbsr	osd_set_bank |  [$b82d: sta    bankswitch_3808]
l_b830:
	GET_REG_BANK_ADDRESS	0,d2                   	| [$b830: lda    ,x+] [bank_address]
	addq.w	#1,d2                           	| [...]
	move.b	(a0),d0                         	| [...]
	OP_R_ON_DP_ADDRESS	add,0x00,d0          | [$b832: adda   $00]
	OP_W_ON_DP_ADDRESS	move,0x00,d0         | [$b834: sta    $00]
	cmp.w	#0x8000,d2                       	| [$b836: cmpx   #$8000]
	jne	l_b830                             	| [$b839: bne    $b830]
	OP_W_ON_DP_ADDRESS	addq,0x01,#1         | [$b83b: inc    $01]
	OP_R_ON_DP_ADDRESS	move,bank_switch_copy_3a,d0| [$b83d: lda    bank_switch_copy_3a]
	add.b	#0x20,d0                         	| [$b83f: adda   #$20] next bank
	OP_W_ON_DP_ADDRESS	move,bank_switch_copy_3a,d0| [$b841: sta    bank_switch_copy_3a]
	OP_R_ON_DP_ADDRESS	move,0x01,d0         | [$b843: lda    $01]
	cmp.b	#0x02,d0                         	| [$b845: cmpa   #$02]
	jne	l_b828                             	| [$b847: bne    $b828]
	move.w	#0xffe0,d3                      	| [$b849: ldy    #$ffe0] contains 3 checksum bytes 5E, 26, 00
	OP_R_ON_DP_ADDRESS	move,0x02,d1         | [$b84d: ldb    $02]
	OP_R_ON_DP_ADDRESS	move,0x00,d0         | [$b84f: lda    $00]
	moveq	#0,d6                            	| [...]
	move.b	d1,d6                           	| [...] as byte
	DO_EXTB	d6                             	| [...] with sign extension
	GET_REG_ADDRESS_FROM_REG	d6,d3         	| [$b851: cmpa   b,y]
	cmp.b	(a0),d0                          	| [...]
	jeq	l_b859                             	| [$b853: beq    $b859]
	move.b	#0x01,d1                        	| [$b855: ldb    #$01] checksum error
	jra	l_b85b                             	| [$b857: bra    $b85b]
l_b859:
	move.b	#0x00,d1                        	| [$b859: ldb    #$00] no error
l_b85b:
	OP_W_ON_DP_ADDRESS	addq,0x02,#1         | [$b85b: inc    $02]
	OP_R_ON_DP_ADDRESS	move,0x02,d0         | [$b85d: lda    $02]
	jbsr	write_diagnostic_message_b8ea     	| [$b85f: jsr    write_diagnostic_message_b8ea]
	OP_R_ON_DP_ADDRESS	move,0x02,d0         | [$b862: lda    $02]
	cmp.b	#0x03,d0                         	| [$b864: cmpa   #$03]
	jne	l_b824                             	| [$b866: bne    $b824]
* checksumming main ROM (ROM 4 in diag screen)
	move.w	#0x8000,d2                      	| [$b868: ldx    #$8000]
	OP_1_ON_DP_ADDRESS	clr,0x00             | [$b86b: clr    $00]
l_b86d:
