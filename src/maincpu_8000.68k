* trigger sub irq
	jbsr	osd_call_sub_irq |  [$b8ae: sta    sub_irq_380f]
* wait some time, let subcpu reply
l_b8b1:
	GET_ADDRESS	irq_sync_flag_0e3e         	| [$b8b1: tst    irq_sync_flag_0e3e]
	tst.b	(a0)                             	| [...]
