	cmp.b	(a0),d0                          	| [...]
	jeq	l_b886                             	| [$b882: beq    $b886]
	move.b	#0x01,d1                        	| [$b884: ldb    #$01] error in main ROM (ROM 4)
l_b886:
	move.b	#0x04,d0                        	| [$b886: lda    #$04]
	jbsr	write_diagnostic_message_b8ea     	| [$b888: jsr    write_diagnostic_message_b8ea]
