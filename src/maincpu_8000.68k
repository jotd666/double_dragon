* now wait for subcpu to reply
	jbsr	wait_subcpu_reply_8ab5            	| [$b8b6: jsr    wait_subcpu_reply_8ab5]
	GET_ADDRESS	subcpu_shared_2000         	| [$b8b9: lda    subcpu_shared_2000] check value that subcpu has put there
	move.b	(a0),d0                         	| [...]
	cmp.b	#0x84,d0                         	| [$b8bc: cmpa   #$84]
	jeq	l_b8ca                             	| [$b8be: beq    $b8ca] it is the expected value: okay!
	move.b	#0x05,d0                        	| [$b8c0: lda    #$05]
	move.b	#0x01,d1                        	| [$b8c2: ldb    #$01]
	jbsr	write_diagnostic_message_b8ea     	| [$b8c4: jsr    write_diagnostic_message_b8ea]
l_b8c7:
