*	PORT_BIT( 0x08, IP_ACTIVE_HIGH, IPT_CUSTOM ) PORT_VBLANK("screen")
*	PORT_BIT( 0x10, IP_ACTIVE_LOW, IPT_CUSTOM ) PORT_READ_LINE_MEMBER(ddragon_state, subcpu_bus_free_r)
*	PORT_BIT( 0xe0, IP_ACTIVE_HIGH, IPT_UNUSED )
*
* there are 8 possible banks (to access them from MAME debugger, ex: "fill 3808:maincpu,1,2<<5" for bank 2 )
* bank 0 contains code
* bank 1 contains code
* bank 2 does not contain code
* bank 3 contains code
* bank 4 contains code
* bank 5 contains code
* bank 6 is empty
* bank 7 is empty
*
* the [banks=0,1,4] tag indicates which known banks are accessed in this jump
*
* interrupt vectors:
* FFF0H to FFF1H 	Reserved by Motorola                     $FFFF
* FFF2H to FFF3H 	SWI3 instruction interrupt vector        $80B9 (not used, RTI)
* FFF4H to FFF5H 	SWI2 instruction interrupt vector        $80B9 (not used, RTI)
* FFF6H to FFF7H 	Fast hardware int. vector (FIRQ)         $8092 freq 0.7ms only to check for inserted coins
* FFF8H to FFF9H 	Hardware interrupt vector (IRQ)          $80B0 controlled by subcpu
* FFFAH to FFFBH 	SWI instruction interrupt vector         $80B9 (not used, RTI)
* FFFCH to FFFDH 	Non-maskable interrupt vector (NMI)      $8056 freq 1/60s (15ms)
* FFFEH to FFFFH 	Reset vector                             $8000

* characters seem to have a 16 color palette each
* ex in intro $1xCx is boss palette, $1xDx is green punk palette



* contains the array on pointers on logical object structures, located just after the array, at $3A2
* a logical object is a combination of sprites
* in intro:
* - 381-38B: garage doors objects
* - 38B-38D: players (03A2,0400)
* - 38F: girl (45E)
* - 391: thug that hits the girl (4B3)
* - 393: green punk (508)
* - 395: thug in white outfit (55D)
* - 397: machine gun boss (5B2)
*
* object structure ($55 bytes for enemies)
* 0:
* 1: object type: examples (from intro)
*    0: player 1
*    1: player 2
*    2: machine gun boss
*    3: punk
*    8: tshirt thug with curly hair
*    9: barechested thug
*    A: hooker
*    14: curtain / platform (level 2)
*    19: elevator door
*    1C: elevator door (green door at level 2)
*    1F: girl
* 2: animation frame id
* 3: direction bit
* 4.W: X coordinate
* 6.W: Y coordinate
* $1F: energy (P1 energy: 3C1, P2: 41F)
* $2d.W: pointer to targeted player (3A2, 400)

reset_8000:                             	| [global]
	moveq	#0,d0                            	| [$8000: clra]
	GET_ADDRESS	nmi_active_flag_0e71       	| [$8001: sta    nmi_active_flag_0e71] nmi is inactive
	move.b	d0,(a0)                         	| [...]
	jbsr	osd_set_bank |  [$8004: sta    bankswitch_3808] set bank 0
	SET_I_FLAG                             	| [$8007: orcc   #$50] disable interrupts
	 |  [$8009: sta    irq_ack_380d]
	 |  [$800c: sta    nmi_ack_380b]
	 |  [$800f: sta    firq_ack_380c]
	moveq	#0,d0                            	| [$8012: clra]
	SET_DP_FROM_A                          	| [$8013: tfr    a,dp] direct page 0
	move.w	#0x0eff,d4                      	| [$8015: ldu    #$0eff] set U stack
	move.w	#0x0fff,d5                      	| [$8018: lds    #$0fff] set S stack
	jbsr	l_fe95                            	| [$801c: jsr    $fe95]
	jbsr	clear_fg_screen_fe98              	| [$801f: jsr    clear_fg_screen_fe98]
	jbsr	clear_bg_screen_fe9b              	| [$8022: jsr    clear_bg_screen_fe9b]
	jbsr	clear_sprite_memory_fe9e          	| [$8025: jsr    clear_sprite_memory_fe9e]
	jbsr	set_screen_orientation_fea1       	| [$8028: jsr    set_screen_orientation_fea1]
	jbsr	set_palettes_fdf0                 	| [$802b: jsr    set_palettes_fdf0]
	CLR_I_FLAG                             	| [$802e: andcc  #$ef]
	OP_R_ON_DP_ADDRESS	move,bank_switch_copy_3a,d0| [$8030: lda    bank_switch_copy_3a]
	and.b	#0xe7,d0                         	| [$8032: anda   #$e7]
	OP_W_ON_DP_ADDRESS	move,bank_switch_copy_3a,d0| [$8034: sta    bank_switch_copy_3a]
	jbsr	osd_set_bank |  [$8036: sta    bankswitch_3808]
	or.b	#0x08,d0                          	| [$8039: ora    #$08]
	OP_W_ON_DP_ADDRESS	move,bank_switch_copy_3a,d0| [$803b: sta    bank_switch_copy_3a]
	jbsr	osd_set_bank |  [$803d: sta    bankswitch_3808]
	jra	memory_check_b7ed                  	| [$8040: jmp    memory_check_b7ed]
l_8043:
	move.b	#0x20,d0                        	| [$8043: lda    #$20]
	jbsr	vbl_delay_b756                    	| [$8045: jsr    vbl_delay_b756]
	jbsr	switch_to_bank_3_ff4a             	| [$8048: jsr    switch_to_bank_3_ff4a]
	jbsr	lb3_6c00                          	| [$804b: jsr    lb3_6c00]
	jbsr	switch_to_bank_0_fc8f             	| [$804e: jsr    switch_to_bank_0_fc8f]
	jra	title_80ba                         	| [$8053: jmp    title_80ba]

nmi_8056:                               	| [global]
	moveq	#0,d0                            	| [$8056: clra]
	SET_DP_FROM_A                          	| [$8057: tfr    a,dp] direct page 0
	GET_ADDRESS	nmi_active_flag_0e71       	| [$8059: ldb    nmi_active_flag_0e71]
	move.b	(a0),d1                         	| [...]
	jpl	l_808e                             	| [$805c: bpl    $808e]
* flag is negative ($80): nmi will do something
	OP_R_ON_DP_ADDRESS	move,interrupt_status_22,d0| [$805e: lda    interrupt_status_22]
	jmi	l_808e                             	| [$8060: bmi    $808e]
	or.b	#0x80,d0                          	| [$8062: ora    #$80]
	OP_W_ON_DP_ADDRESS	move,interrupt_status_22,d0| [$8064: sta    interrupt_status_22] bit 7 to tell that we're within the nmi
	OP_W_ON_DP_ADDRESS	addq,0x2f,#1         | [$8066: inc    $2f]
	OP_R_ON_DP_ADDRESS	move,interrupt_status_22,d0| [$8068: lda    interrupt_status_22]
	and.b	#0x01,d0                         	| [$806a: anda   #$01]
	jeq	l_8088                             	| [$806c: beq    $8088] skip if bit 0 is not set
* main graphic update
	jbsr	update_scrolling_fdfc             	| [$806e: jsr    update_scrolling_fdfc]
	jbsr	save_and_switch_to_bank_0_ff24    	| [$8071: jsr    save_and_switch_to_bank_0_ff24]
	jbsr	update_sprite_memory_fea4         	| [$8074: jsr    update_sprite_memory_fea4] copy from subcpu memory to sprite memory
	jbsr	set_bg_tiles_palette_fea7         	| [$8077: jsr    set_bg_tiles_palette_fea7]
	jbsr	set_palettes_fdf3                 	| [$807a: jsr    set_palettes_fdf3]
	jbsr	restore_previous_bank_ff34        	| [$807d: jsr    restore_previous_bank_ff34]
* "ack" nmi graphic update by setting bit 2
	OP_R_ON_DP_ADDRESS	move,interrupt_status_22,d0| [$8080: lda    interrupt_status_22]
	or.b	#0x02,d0                          	| [$8082: ora    #$02]
	OP_W_ON_DP_ADDRESS	move,interrupt_status_22,d0| [$8084: sta    interrupt_status_22]
	OP_1_ON_DP_ADDRESS	clr,0x2f             | [$8086: clr    $2f]
l_8088:
	OP_R_ON_DP_ADDRESS	move,interrupt_status_22,d0| [$8088: lda    interrupt_status_22]
	and.b	#0x7f,d0                         	| [$808a: anda   #$7f]
	OP_W_ON_DP_ADDRESS	move,interrupt_status_22,d0| [$808c: sta    interrupt_status_22] clear bit 7 to tell that we're outside the nmi
l_808e:
	 |  [$808e: sta    nmi_ack_380b] ack our interrupt
	rts |  [$8091: rti]

* only useful to check for coins. Disable it (bpset 8094,,{PC=$80AA;g} and
* everything works except the insert coin buttons
* called every 0.7ms this is probably to be sure not to miss any coins

firq_8092:                              	| [global]
	PUSH_SR                                	| [$8092: pshs   u,y,x,dp,d,cc]
	movem.l	D0/D1/d2/d3/d4,-(sp)           	| [$8092: pshs   u,y,x,dp,d,cc]
	move.l	a5,-(sp)                        	| [$8092: pshs   u,y,x,dp,d,cc]
	moveq	#0,d0                            	| [$8094: clra]
	SET_DP_FROM_A                          	| [$8095: tfr    a,dp] direct page 0
	OP_R_ON_DP_ADDRESS	move,interrupt_status_22,d0| [$8097: lda    interrupt_status_22]
	BIT	#0x20,d0                           	| [$8099: bita   #$20]
	jne	l_80aa                             	| [$809b: bne    $80aa]
	or.b	#0x20,d0                          	| [$809d: ora    #$20]
	OP_W_ON_DP_ADDRESS	move,interrupt_status_22,d0| [$809f: sta    interrupt_status_22]
	jbsr	check_for_coin_inserted_8990      	| [$80a1: jsr    check_for_coin_inserted_8990]
	OP_R_ON_DP_ADDRESS	move,interrupt_status_22,d0| [$80a4: lda    interrupt_status_22]
	and.b	#0xdf,d0                         	| [$80a6: anda   #$df]
	OP_W_ON_DP_ADDRESS	move,interrupt_status_22,d0| [$80a8: sta    interrupt_status_22]
l_80aa:
	 |  [$80aa: sta    firq_ack_380c] ack our interrupt
	move.l	(sp)+,a5
	STORE_DP_IN_MEMORY
	movem.l	(sp)+,D0/D1/d2/d3/d4           	| [$80ad: puls   cc,d,dp,x,y,u]
	POP_SR                                 	| [$80ad: puls   cc,d,dp,x,y,u]
	rts |  [$80af: rti]

* irq is just there to set sync flag
irq_80b0:                               	| [global]
	move.b	#0x01,d0                        	| [$80b0: lda    #$01]
	GET_ADDRESS	irq_sync_flag_0e3e         	| [$80b2: sta    irq_sync_flag_0e3e] set sync flag
	move.b	d0,(a0)                         	| [...]
	 |  [$80b5: sta    irq_ack_380d] ack our interrupt
	rts |  [$80b8: rti]

* this is not used
swi_interrupt:
	rts |  [$80b9: rti]

title_80ba:
	move.b	#0xff,d0                        	| [$80ba: lda    #$ff]
	jbsr	osd_sound_start |  [$80bc: sta    sound_irq_380e]
	move.b	#0xff,d1                        	| [$80bf: ldb    #$ff]
l_80c1:
	subq.b	#1,d1                           	| [$80c1: decb]
	LOAD_CONTEXT	TITLE |  [$80c2: bne    $80c1]
	move.b	#0xfe,d0                        	| [$80c4: lda    #$fe]
	jbsr	osd_sound_start |  [$80c6: sta    sound_irq_380e]
	GET_DP_ADDRESS	0x23                    	| [$80c9: ldx    $23]
	MOVE_W_TO_REG	a0,d2                         	| [...]
	OP_R_ON_DP_ADDRESS	move,0x25,d0         | [$80cb: lda    $25]
	OP_R_ON_DP_ADDRESS	move,bank_switch_copy_3a,d1| [$80cd: ldb    bank_switch_copy_3a]
	movem.l	D0/D1/d2,-(sp)                 	| [$80cf: pshs   x,d]
	GET_DP_ADDRESS	0x2d                    	| [$80d1: ldx    $2d]
	MOVE_W_TO_REG	a0,d2                         	| [...]
	GET_DP_ADDRESS	0x20                    	| [$80d3: ldd    $20]
	LOAD_D                                 	| [$80d3: ldd    $20]
	movem.l	D0/D1/d2,-(sp)                 	| [$80d5: pshs   x,d]
	OP_R_ON_DP_ADDRESS	move,0xcc,d0         | [$80d7: lda    $cc]
	move.l	d0,-(sp)                        	| [$80d9: pshs   a]
	jbsr	l_fe95                            	| [$80db: jsr    $fe95]
	movem.l	(sp)+,d0                       	| [$80de: puls   a]
	MAKE_D                                 	| [...]
	OP_W_ON_DP_ADDRESS	move,0xcc,d0         | [$80e0: sta    $cc]
	movem.l	(sp)+,D0/D1/d2                 	| [$80e2: puls   d,x]
	GET_DP_ADDRESS	0x2d                    	| [$80e4: stx    $2d]
	MOVE_W_FROM_REG	d2,a0                         	| [...]
	MAKE_D                                 	| [...]
	GET_DP_ADDRESS	0x20                    	| [$80e6: std    $20]
	MOVE_W_FROM_REG	d1,a0                         	| [...]
	movem.l	(sp)+,D0/D1/d2                 	| [$80e8: puls   d,x]
	GET_DP_ADDRESS	0x23                    	| [$80ea: stx    $23]
	MOVE_W_FROM_REG	d2,a0                         	| [...]
	OP_W_ON_DP_ADDRESS	move,0x25,d0         | [$80ec: sta    $25]
	OP_W_ON_DP_ADDRESS	move,bank_switch_copy_3a,d1| [$80ee: stb    bank_switch_copy_3a]
