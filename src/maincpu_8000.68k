	rts                                    	| [...]

switch_to_bank_3_ff9c:
	PUSH_SR  | save carry
	move.l	d0,-(sp)                        	| [$ff9c: pshs   a]
	OP_R_ON_DP_ADDRESS	move,bank_switch_copy_3a,d0| [$ff9e: lda    bank_switch_copy_3a]
	and.b	#0x1f,d0                         	| [$ffa0: anda   #$1f]
	or.b	#0x60,d0                          	| [$ffa2: ora    #$60] bank=3
	OP_W_ON_DP_ADDRESS	move,bank_switch_copy_3a,d0| [$ffa4: sta    bank_switch_copy_3a]
	jbsr	osd_set_bank |  [$ffa6: sta    bankswitch_3808]
	movem.l	(sp)+,d0                       	| [$ffa9: puls   a,pc]
	POP_SR | restore carry
	PUSH_SR                                	| [...]
	MAKE_D                                 	| [...]
	POP_SR                                 	| [...]
	rts                                    	| [...]

