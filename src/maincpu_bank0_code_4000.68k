	move.b	(a0),d0                         	| [...]
	COM	d0                                 	| [$4466: coma]
	and.b	#0x3f,d0                         	| [$4467: anda   #$3f] controls (directions & buttons)
	move.b	d0,d1                           	| [$4469: tfr    a,b] separate directions & buttons
	and.b	#0x30,d0                         	| [$446b: anda   #$30] A: buttons (kick & jump)
