* < X: pointer on object to push
lb1_push_one_sprite_entry_4100:
	movem.l	D0/D1/d3,-(sp)                 	| [$4100: pshs   y,d]
	move.w	#logical_objects_array_0381,d3  	| [$4102: ldy    #logical_objects_array_0381]
	GET_ADDRESS	nb_objects_to_convert_03a1 	| [$4106: lda    nb_objects_to_convert_03a1]
	move.b	(a0),d0                         	| [...]
	cmp.b	#0x20,d0                         	| [$4109: cmpa   #$20]
	jcc	lb1_411c                           	| [$410b: bcc    $411c] too much: out
	GET_REG_ADDRESS	0x2,d2                 	| [$410d: ldb    $2,x]
	move.b	(a0),d1                         	| [...]
	and.b	#0x7f,d1                         	| [$410f: andb   #$7f]
	cmp.b	#0x7f,d1                         	| [$4111: cmpb   #$7f]
	jeq	lb1_411c                           	| [$4113: beq    $411c] inactive: out
	moveq	#0,d6                            	| [...]
	move.b	d0,d6                           	| [...] as byte
	DO_EXTB	d6                             	| [...] with sign extension
	GET_REG_ADDRESS_FROM_REG	d6,d3         	| [$4115: stx    a,y]
	MOVE_W_FROM_REG	d2,a0                         	| [...]
	add.b	#0x02,d0                         	| [$4117: adda   #$02]
	GET_ADDRESS	nb_objects_to_convert_03a1 	| [$4119: sta    nb_objects_to_convert_03a1]
	move.b	d0,(a0)                         	| [...]
lb1_411c:
	movem.l	(sp)+,D0/D1/d3                 	| [$411c: puls   d,y,pc]
	rts                                    	| [...]

* < X
subcpu_processing_411e:
	move.l	d4,-(sp)                        	| [$411e: pshs   u]
	OP_R_ON_DP_ADDRESS	move,bank_switch_copy_3a,d0| [$4120: lda    bank_switch_copy_3a]
	or.b	#0x10,d0                          	| [$4122: ora    #$10]
	OP_W_ON_DP_ADDRESS	move,bank_switch_copy_3a,d0| [$4124: sta    bank_switch_copy_3a]
	jbsr	osd_set_bank |  [$4126: sta    bankswitch_3808]
* wait for subcpu to be ready
lb1_4129:
	GET_ADDRESS	extra_3802                 	| [$4129: lda    extra_3802]
	move.b	(a0),d0                         	| [...]
	and.b	#0x10,d0                         	| [$412c: anda   #$10]
	jne	lb1_4129                           	| [$412e: bne    $4129]
	GET_ADDRESS	subcpu_shared_2000         	| [$4130: clr    subcpu_shared_2000]
	clr.b	(a0)                         	| [...]
	GET_DP_ADDRESS	0x3c                    	| [$4133: ldd    $3c]
	LOAD_D                                 	| [$4133: ldd    $3c]
	GET_ADDRESS	0x21f9                     	| [$4135: std    $21f9]
	MOVE_W_FROM_REG	d1,a0                         	| [...]
	GET_DP_ADDRESS	0x3f                    	| [$4138: ldd    $3f]
	LOAD_D                                 	| [$4138: ldd    $3f]
	GET_ADDRESS	0x21fb                     	| [$413a: std    $21fb]
	MOVE_W_FROM_REG	d1,a0                         	| [...]
	OP_R_ON_DP_ADDRESS	move,0x2b,d0         | [$413d: lda    $2b]
	GET_ADDRESS	0x21fe                     	| [$413f: sta    $21fe]
	move.b	d0,(a0)                         	| [...]
	GET_ADDRESS	0x21fd                     	| [$4142: clr    $21fd]
	clr.b	(a0)                         	| [...]
	GET_ADDRESS	nb_objects_to_convert_03a1 	| [$4145: tst    nb_objects_to_convert_03a1]
	tst.b	(a0)                             	| [...]
	jeq	lb1_41f3                           	| [$4148: lbeq   $41f3] no sprites to transform: out
	move.w	#logical_objects_array_0381,d3  	| [$414c: ldy    #logical_objects_array_0381]
	move.w	#0x2001,d4                      	| [$4150: ldu    #$2001] fill exchange zone
	moveq	#0,d1                            	| [$4153: clrb]
* loop
lb1_4154:
	moveq	#0,d6                            	| [...]
	move.b	d1,d6                           	| [...] as byte
	DO_EXTB	d6                             	| [...] with sign extension
	GET_REG_ADDRESS_FROM_REG	d6,d3         	| [$4154: ldx    b,y] load source offset
	MOVE_W_TO_REG	a0,d2                         	| [...]
	GET_REG_ADDRESS	0x1,d2                 	| [$4156: lda    $1,x] load data
	move.b	(a0),d0                         	| [...]
	GET_REG_ADDRESS	0,d4                   	| [$4158: sta    ,u] store in exchange zone
	move.b	d0,(a0)                         	| [...]
	GET_REG_ADDRESS	0x2,d2                 	| [$415a: lda    $2,x] repeat ad nauseam
	move.b	(a0),d0                         	| [...]
