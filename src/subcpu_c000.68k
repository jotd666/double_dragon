rom_checksum_c058:
	LOG_REGS	c058,-2   | added by add_reg_log.py
	move.w	#0xc000,d2                      	| [$c058: ldx  #$c000]
	LOG_REGS	c05b,-2   | added by add_reg_log.py
	GET_ROM_REG_ADDRESS	0x00,d2                	| [$c05b: lda  $00,x] [rom]
	move.b	(a0),d0                         	| [...]
	LOG_REGS	c05d,-2   | added by add_reg_log.py
	addq.w	#1,d2                           	| [$c05d: inx]
sub_c05e:
	LOG_REGS	c05e,-2   | added by add_reg_log.py
	GET_ROM_REG_ADDRESS	0x00,d2                	| [$c05e: adda $00,x] [rom]
	add.b	(a0),d0                          	| [...]
	LOG_REGS	c060,-2   | added by add_reg_log.py
	addq.w	#1,d2                           	| [$c060: inx]
	LOG_REGS	c061,-2   | added by add_reg_log.py
	jne	sub_c05e                           	| [$c061: bne  $c05e]
	LOG_REGS	c063,-2   | added by add_reg_log.py
	GET_SHARED_ADDRESS	shared_memory_8000         	| [$c063: sta  shared_memory_8000] write the result of the checksum here so maincpu can collect it
	move.b	d0,(a0)                         	| [...]
	LOG_REGS	c066,-2   | added by add_reg_log.py
	OP_W_ON_DP_ADDRESS	addq,irq_already_called_0066,#1| [$c066: inc  irq_already_called_0066]
	LOG_REGS	c069,-2   | added by add_reg_log.py
	jra	irq_end_c039                       	| [$c069: jmp  irq_end_c039]

