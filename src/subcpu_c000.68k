	.include	"data.inc"
	.global	sub_boot_c009
	.global	sub_irq_c02e
	.include "double_dragon_sub.inc"

*	map(0x8000, 0x81ff).ram().share(m_comram);  => 0x2000 on main cpu

*	map(0x0020, 0x0fff).ram();

*	map(0xc000, 0xffff).rom();

irq_already_called_0066 = 0x66
shared_memory_8000 = 0x8000
copy_of_port6_0065 = 0x65
port6_0017 = 0x17

* aux. cpu to help main cpu
sub_c000:
sub_c001:
sub_c002:
sub_c003:
sub_c004:
sub_c005:
sub_c006:
sub_c007:
sub_c008:
sub_boot_c009:                          	| [global]
sub_c009:
	 |  [$c009: lds  #$013f] set stack
	move.b	#0xff,d0                        	| [$c00c: lda  #$ff]
	OP_W_ON_DP_ADDRESS	move,0x05,d0         | [$c00e: sta  $05]
	OP_W_ON_DP_ADDRESS	move,0x16,d0         | [$c010: sta  $16]
	move.b	#0x10,d0                        	| [$c012: lda  #$10]
	 |  [$c014: tap] interrupt handling
	OP_1_ON_DP_ADDRESS	clr,irq_already_called_0066| [$c015: clr  irq_already_called_0066]
	OP_1_ON_DP_ADDRESS	clr,copy_of_port6_0065| [$c018: clr  copy_of_port6_0065]
	OP_R_ON_DP_ADDRESS	move,copy_of_port6_0065,d0| [$c01b: lda  copy_of_port6_0065]
	and.b	#0xfe,d0                         	| [$c01d: anda #$fe]
	OP_W_ON_DP_ADDRESS	move,copy_of_port6_0065,d0| [$c01f: sta  copy_of_port6_0065]
	OP_W_ON_DP_ADDRESS	move,port6_0017,d0   | [$c021: sta  port6_0017]
	move.b	#0x01,d0                        	| [$c023: lda  #$01]
	GET_DP_ADDRESS	copy_of_port6_0065      	| [$c025: ora  copy_of_port6_0065]
	or.b	(a0),d0                           	| [...]
	OP_W_ON_DP_ADDRESS	move,copy_of_port6_0065,d0| [$c027: sta  copy_of_port6_0065]
	OP_W_ON_DP_ADDRESS	move,port6_0017,d0   | [$c029: sta  port6_0017]
sub_c02b:
	rts |  [$c02b: jmp  $c02b] infinite loop, wait for main cpu orders

* triggered when sprites need displaying
sub_irq_c02e:                           	| [global]
sub_c02e:
	OP_1_ON_DP_ADDRESS	tst,irq_already_called_0066| [$c02e: tst  irq_already_called_0066]
	jne	sub_c036                           	| [$c031: bne  $c036]
* first time IRQ is called it checksums the memory, other times it
* convert sprites coordinates
	jra	rom_checksum_c058                  	| [$c033: jmp  rom_checksum_c058]
sub_c036:
	jbsr	sprite_convert_c06c               	| [$c036: jsr  sprite_convert_c06c]
irq_end_c039:
* send a pulse to trigger main cpu IRQ
	jbra	osd_call_main_irq |  [$c039: lda  copy_of_port6_0065]
	 |  [$c03b: anda #$fd]
	 |  [$c03d: sta  copy_of_port6_0065]
	 |  [$c03f: sta  port6_0017]
	 |  [$c041: lda  #$02]
	 |  [$c043: ora  copy_of_port6_0065]
	 |  [$c045: sta  copy_of_port6_0065]
	 |  [$c047: lda  copy_of_port6_0065]
	 |  [$c049: anda #$fe]
	 |  [$c04b: sta  copy_of_port6_0065]
	 |  [$c04d: sta  port6_0017]
	 |  [$c04f: lda  #$01]
	 |  [$c051: ora  copy_of_port6_0065]
	 |  [$c053: sta  copy_of_port6_0065]
	 |  [$c055: sta  port6_0017]

rom_checksum_c058:
	move.w	#0xc000,d2                      	| [$c058: ldx  #$c000]
	GET_ROM_REG_ADDRESS	0x00,d2                	| [$c05b: lda  $00,x] [rom]
	move.b	(a0),d0                         	| [...]
	addq.w	#1,d2                           	| [$c05d: inx]
sub_c05e:
	GET_ROM_REG_ADDRESS	0x00,d2                	| [$c05e: adda $00,x] [rom]
	add.b	(a0),d0                          	| [...]
	addq.w	#1,d2                           	| [$c060: inx]
	jne	sub_c05e                           	| [$c061: bne  $c05e]
	GET_SHARED_ADDRESS	shared_memory_8000         	| [$c063: sta  shared_memory_8000] write the result of the checksum here so maincpu can collect it
	move.b	d0,(a0)                         	| [...]
	OP_W_ON_DP_ADDRESS	addq,irq_already_called_0066,#1| [$c066: inc  irq_already_called_0066] next time do the real processing, not rom checksum
	jra	irq_end_c039                       	| [$c069: jmp  irq_end_c039]

sprite_convert_c06c:
	jbsr	sub_c0a8                          	| [$c06c: jsr  $c0a8]
	move.w	#0x8001,d2                      	| [$c06f: ldx  #$8001] load X with start of shared memory
											| [$c072: lda  #$01]
	OP_W_ON_DP_ADDRESS	move,0x4f,#1         | [$c074: sta  $4f]
sub_c076:
	OP_R_ON_DP_ADDRESS	move,0x4f,d0         | [$c076: lda  $4f]
	cmp.b	(a5),d0				         	| [$c078: cmpa shared_memory_8000]
	jcc	sub_c0a4                           	| [$c07b: bcc  $c0a4]
	GET_REG_ADDRESS	0x00,d2                	| [$c07d: ldd  $00,x]
	move.l	a0,a2
	move.w	(a2),(0x40,a6)                  | [$c07d: ldd  $00,x]
											| [$c07f: std  $40]
	move.l	(0x02,a2),(0x42,a6)             | [$c081: ldd  $02,x]
											| [$c083: std  $42]
											| [$c085: ldd  $04,x]
											| [$c087: std  $44]
	move.w	(0x06,a2),(0x46,a6)            	| [$c089: ldd  $06,x]
	                                	| [$c089: ldd  $06,x]
										| [$c08b: std  $46]
	move.w	d2,-(sp)                        	| [$c08d: pshx]
	OP_R_ON_DP_ADDRESS	move,0x41,d1         | [$c08e: ldb  $41]
	and.b	#0x7f,d1                         	| [$c090: andb #$7f]
	cmp.b	#0x7f,d1                         	| [$c092: cmpb #$7f]
	jeq	sub_c099                           	| [$c094: beq  $c099]
	jbsr	heavy_lifting_c10b                	| [$c096: jsr  heavy_lifting_c10b]
sub_c099:
	moveq	#0x08,d1                        	| [$c099: ldb  #$08]
	move.w	(sp)+,d2                        	| [$c09b: pulx]
	ABX                                    	| [$c09c: abx]
	add.b	d1,(0x4f,a6)         | [$c09d: lda  $4f] [manual_optim]
	     	| [$c09f: aba]
	       | [$c0a0: sta  $4f]
	jra	sub_c076                           	| [$c0a2: bra  $c076]
sub_c0a4:
	         	| [$c0a4: clr  shared_memory_8000]
	clr.b	(a5)                         	| [...]
	rts                                    	| [$c0a7: rts]

sub_c0a8:
	         	| [$c0a8: tst  shared_memory_8000]
	tst.b	(a5)                             	| [...]
	jeq	sub_c10a                           	| [$c0ab: beq  $c10a] 0: return immediately
* main cpu is asking for work
sub_c0ad:
	OP_1_ON_DP_ADDRESS	clr,0x004f           | [$c0ad: clr  $004f]
											| [$c0b0: lda  #$01]
	OP_W_ON_DP_ADDRESS	move,0x4e,#1         | [$c0b2: sta  $4e]
sub_c0b4:
	OP_R_ON_DP_ADDRESS	move,0x4e,d0         | [$c0b4: lda  $4e]
	add.b	#0x08,d0                         	| [$c0b6: adda #$08]
									| [$c0b8: cmpa shared_memory_8000]
	cmp.b	(a5),d0                          	| [...]
	jcc	sub_c105                           	| [$c0bb: bcc  $c105]
	move.w	#shared_memory_8000,d2          	| [$c0bd: ldx  #shared_memory_8000]
	OP_R_ON_DP_ADDRESS	move,0x4e,d1         | [$c0c0: ldb  $4e]
	ABX                                    	| [$c0c2: abx]
	* hand-optimized, this is coordinate conversion, called a lot
	GET_REG_ADDRESS	0x0,d2
	move.l 	a0,a2
	move.w	(0x04,a2),d1                	| [$c0c3: ldd  $04,x]
	sub.w	(0x0c,a2),d1                	| [$c0c5: subd $0c,x]
	jcc	sub_c0fc                           	| [$c0c7: bcc  $c0fc]
	move.w	(0x00,a2),(0x40,a6)             | [$c0c9: ldd  $00,x]
											| [$c0cb: std  $40]
	move.w	(0x08,a2),(a2)                	| [$c0cd: ldd  $08,x]
											| [$c0cf: std  $00,x]
	move.w	(0x40,a6),(0x08,a2)            	| [$c0d1: ldd  $40]
											| [$c0d3: std  $08,x]
	move.w	(0x02,a2),(0x40,a6)           	| [$c0d5: ldd  $02,x]
											| [$c0d7: std  $40]
	move.w	(0x0a,a2),(0x02,a2)             | [$c0d9: ldd  $0a,x]
											| [$c0db: std  $02,x]
	move.w	(0x40,a6),(0x0A,a2)             | [$c0dd: ldd  $40]
											| [$c0df: std  $0a,x]
	move.w	(0x04,a2),(0x40,a6)            	| [$c0e1: ldd  $04,x]
											| [$c0e3: std  $40]
	move.w	(0x0c,a2),(0x04,a2)             | [$c0e5: ldd  $0c,x]
											| [$c0e7: std  $04,x]
	move.w	(0x40,a6),(0x0c,a2)           	| [$c0e9: ldd  $40]
											| [$c0eb: std  $0c,x]
	move.w	(0x06,a2),(0x40,a6)           	| [$c0ed: ldd  $06,x]
											| [$c0ef: std  $40]
	move.w	(0x0e,a2),(0x06,a2)            	| [$c0f1: ldd  $0e,x]
											| [$c0f3: std  $06,x]
	move.w	(0x40,a6),(0x0E,a2)            	| [$c0f5: ldd  $40]
											| [$c0f7: std  $0e,x]
	OP_W_ON_DP_ADDRESS	addq,0x004f,#1       | [$c0f9: inc  $004f]
sub_c0fc:
	         | [$c0fc: lda  $4e]
	add.b	#0x08,(0x4E,a6)                         	| [$c0fe: adda #$08]
	         | [$c100: sta  $4e]
	jra	sub_c0b4                           	| [$c102: jmp  $c0b4]
sub_c105:
	OP_1_ON_DP_ADDRESS	tst,0x004f           | [$c105: tst  $004f]
	jne	sub_c0ad                           	| [$c108: bne  $c0ad]
sub_c10a:
	rts                                    	| [$c10a: rts]

heavy_lifting_c10b:
									| [$c10b: lda  $81fd]
	move.b	(0x1FD,a5),d0                         	| [...]
	cmp.b	#0x4b,d0                         	| [$c10e: cmpa #$4b]
	jcs	sub_c115                           	| [$c110: bcs  $c115]
	jra	sub_c27e                           	| [$c112: jmp  $c27e] do nothing
sub_c115:
	GET_DP_ADDRESS	0x44                    	| [$c115: ldd  $44]
	LOAD_D                                 	| [$c115: ldd  $44]
	GET_DP_ADDRESS	0x46                    	| [$c117: addd $46]
	ADD_W_TO_REG	a0,d1                          	| [...]
	GET_SHARED_ADDRESS	0x81fb                     	| [$c119: subd $81fb]
	SUB_W_TO_REG	a0,d1                          	| [...]
	GET_DP_ADDRESS	0x56                    	| [$c11c: std  $56]
	MOVE_W_FROM_REG	d1,a0                         	| [...]
	move.w	(0x42,a6),d1                    	| [$c11e: ldd  $42]
	GET_SHARED_ADDRESS	0x81f9                     	| [$c120: subd $81f9]
	SUB_W_TO_REG	a0,d1                          	| [...]
	GET_DP_ADDRESS	0x58                    	| [$c123: std  $58]
	MOVE_W_FROM_REG	d1,a0                         	| [...]
	OP_R_ON_DP_ADDRESS	move,0x41,d0         | [$c125: lda  $41]
                                         | [$c127: lsra]
                                         | [$c128: lsra]
                                         | [$c129: lsra]
	lsr.b	#4,d0                            	| [$c12a: lsra]
	and.b	#0x08,d0                         	| [$c12b: anda #$08]
	OP_W_ON_DP_ADDRESS	move,0x54,d0         | [$c12d: sta  $54]
	OP_R_ON_DP_ADDRESS	move,0x40,d1         | [$c12f: ldb  $40]
	OP_W_ON_DP_ADDRESS	move,0x5e,d1         | [$c131: stb  $5e]
	and.b	#0x7f,d1                         	| [$c133: andb #$7f]
	OP_W_ON_DP_ADDRESS	move,0x5f,d1         | [$c135: stb  $5f]
	asl.b	#1,d1                            	| [$c137: aslb]
	move.w	#0xc2ef,d2                      	| [$c138: ldx  #$c2ef]
	ABX                                    	| [$c13b: abx]
	GET_ROM_REG_ADDRESS	0x00,d2                	| [$c13c: ldx  $00,x] [rom]
	MOVE_W_TO_REG	a0,d2                         	| [...]
	OP_R_ON_DP_ADDRESS	move,0x41,d1         | [$c13e: ldb  $41]
	and.b	#0x7f,d1                         	| [$c140: andb #$7f]
	ABX                                    	| [$c142: abx]
	ABX                                    	| [$c143: abx]
	GET_ROM_REG_ADDRESS	0x00,d2                	| [$c144: ldx  $00,x] [rom]
	MOVE_W_TO_REG	a0,d2                         	| [...]
	GET_DP_ADDRESS	0x48                    	| [$c146: stx  $48]
	MOVE_W_FROM_REG	d2,a0                         	| [...]
	GET_SHARED_ADDRESS	0x81fd                     	| [$c148: ldb  $81fd]
	move.b	(a0),d1                         	| [...]
	move.b	#0x05,d0                        	| [$c14b: lda  #$05]
	jbsr	multiply_ab                       	| [$c14d: mul]
	add.w	#0x8081,d1                       	| [$c14e: addd #$8081]
	GET_DP_ADDRESS	0x4a                    	| [$c151: std  $4a]
	MOVE_W_FROM_REG	d1,a0                         	| [...]
	GET_DP_ADDRESS	0x48                    	| [$c153: ldx  $48]
	MOVE_W_TO_REG	a0,d2                         	| [...]
	GET_ROM_REG_ADDRESS	0x00,d2                	| [$c155: ldb  $00,x] [rom]
	move.b	(a0),d1                         	| [...]
	addq.w	#1,d2                           	| [$c157: inx]
	OP_1_ON_DP_ADDRESS	clr,0x0050           | [$c158: clr  $0050]
	OP_1_ON_DP_ADDRESS	clr,0x0052           | [$c15b: clr  $0052]
	OP_1_ON_DP_ADDRESS	clr,0x005a           | [$c15e: clr  $005a]
	OP_W_ON_DP_ADDRESS	move,0x4e,d1         | [$c161: stb  $4e]
	TBA                                    	| [$c163: tba]
	and.b	#0x1f,d0                         	| [$c164: anda #$1f]
	OP_W_ON_DP_ADDRESS	move,0x53,d0         | [$c166: sta  $53]
	tst.b	d1                               	| [$c168: tstb]
	jpl	sub_c170                           	| [$c169: bpl  $c170]
	GET_ROM_REG_ADDRESS	0x00,d2                	| [$c16b: lda  $00,x] [rom]
	move.b	(a0),d0                         	| [...]
	addq.w	#1,d2                           	| [$c16d: inx]
	OP_W_ON_DP_ADDRESS	move,0x50,d0         | [$c16e: sta  $50]
sub_c170:
	BIT	#0x40,d1                           	| [$c170: bitb #$40]
	jeq	sub_c17c                           	| [$c172: beq  $c17c]
	GET_ROM_REG_ADDRESS	0x00,d2                	| [$c174: lda  $00,x] [rom]
	move.b	(a0),d0                         	| [...]
	addq.w	#1,d2                           	| [$c176: inx]
	OP_W_ON_DP_ADDRESS	move,0x51,d0         | [$c177: sta  $51]
	not.b	(0x52,a6)                  	     | [$c179: com  $0052]
sub_c17c:
	BIT	#0x20,d1                           	| [$c17c: bitb #$20]
	jeq	loop_c189                           	| [$c17e: beq  $c189]
	not.b	(0x5A,a6)                           | [$c180: com  $005a]
	GET_ROM_REG_ADDRESS	0x00,d2                	| [$c183: ldd  $00,x] [rom]
	LOAD_D                                 	| [$c183: ldd  $00,x] [rom]
                                              | [$c185: inx]
	addq.w	#2,d2                           	| [$c186: inx]
	GET_DP_ADDRESS	0x4c                    	| [$c187: std  $4c]
	MOVE_W_FROM_REG	d1,a0                         	| [...]
* loop
loop_c189:
	OP_R_ON_DP_ADDRESS	move,0x4e,d0         | [$c189: lda  $4e]
	jpl	sub_c191                           	| [$c18b: bpl  $c191]
	OP_R_ON_DP_ADDRESS	move,0x50,d0         | [$c18d: lda  $50]
	jra	sub_c194                           	| [$c18f: bra  $c194]
sub_c191:
	GET_ROM_REG_ADDRESS	0x00,d2                	| [$c191: lda  $00,x] [rom]
	move.b	(a0),d0                         	| [...]
	addq.w	#1,d2                           	| [$c193: inx]
sub_c194:
	move.w	d0,-(sp)                        	| [$c194: psha]
	and.b	#0x0f,d0                         	| [$c195: anda #$0f]
	GET_DP_ADDRESS	0x48                    	| [$c197: stx  $48]
	MOVE_W_FROM_REG	d2,a0                         	| [...]
	move.w	#0xc27f,d2                      	| [$c199: ldx  #$c27f]
	OP_R_ON_DP_ADDRESS	move,0x5f,d1         | [$c19c: ldb  $5f]
	* multiply by 3
	move.b	d1,d6
	asl.b	#1,d1                            	| [$c19e: aslb]
	add.b	d6,d1				          | [$c19f: addb $5f]
	ABX                                    	| [$c1a1: abx]
	move.w	(sp),d1                        	| [$c1a2: pulb]
											| [$c1a3: pshb]
	and.b	#0x30,d1                      | [$c1a4: andb #$30]
                                         | [$c1a6: lsrb]
                                         | [$c1a7: lsrb]
                                         | [$c1a8: lsrb]
	lsr.b	#4,d1                            	| [$c1a9: lsrb]
	ABX                                    	| [$c1aa: abx]
	GET_ROM_REG_ADDRESS	0x00,d2                	| [$c1ab: ora  $00,x] [rom]
	or.b	(a0),d0                           	| [...]
	OP_W_ON_DP_ADDRESS	move,0x62,d0         | [$c1ad: sta  $62]
	and.b	#0xf0,d0                         	| [$c1af: anda #$f0]
	cmp.b	#0x20,d0                         	| [$c1b1: cmpa #$20]
	jcc	sub_c1bf                           	| [$c1b3: bcc  $c1bf]
	OP_R_ON_DP_ADDRESS	move,0x5e,d0         | [$c1b5: lda  $5e]
	jpl	sub_c1bf                           	| [$c1b7: bpl  $c1bf]
	OP_R_ON_DP_ADDRESS	move,0x62,d0         | [$c1b9: lda  $62]
	eor.b	#0x10,d0                         	| [$c1bb: eora #$10]
	OP_W_ON_DP_ADDRESS	move,0x62,d0         | [$c1bd: sta  $62]
sub_c1bf:
	move.w	(sp)+,d1                        	| [$c1bf: pulb]
                                         | [$c1c0: lsrb]
                                         | [$c1c1: lsrb]
                                         | [$c1c2: lsrb]
                                         | [$c1c3: lsrb]
                                         | [$c1c4: lsrb]
	lsr.b	#6,d1                            	| [$c1c5: lsrb]
	move.w	#0xc2eb,d2                      	| [$c1c6: ldx  #$c2eb]
	ABX                                    	| [$c1c9: abx]
	OP_1_ON_DP_ADDRESS	clr,0x0061           | [$c1ca: clr  $0061]
	OP_R_ON_DP_ADDRESS	move,0x61,d0         | [$c1cd: lda  $61]
	GET_ROM_REG_ADDRESS	0x00,d2                	| [$c1cf: ora  $00,x] [rom]
	or.b	(a0),d0                           	| [...]
	OP_W_ON_DP_ADDRESS	move,0x61,d0         | [$c1d1: sta  $61]
	GET_DP_ADDRESS	0x48                    	| [$c1d3: ldx  $48]
	MOVE_W_TO_REG	a0,d2                         	| [...]
	OP_R_ON_DP_ADDRESS	move,0x61,d1         | [$c1d5: lda  $61]
        
	move.b	(0x54,a6),d6        	| [$c1d7: eora $54]
	eor.b	d6,d1                          	| [...]
	or.b	#0x80,d1                          	| [$c1d9: ora  #$80]
	OP_W_ON_DP_ADDRESS	move,0x61,d1         | [$c1db: sta  $61]
	OP_R_ON_DP_ADDRESS	move,0x51,d0         | [$c1dd: lda  $51]
	OP_W_ON_DP_ADDRESS	addq,0x0051,#1       | [$c1df: inc  $0051]       
										| [$c1e2: ldb  $61] d1 used above
	BIT	#0x10,d1                           	| [$c1e4: bitb #$10]
	jeq	sub_c1eb                           	| [$c1e6: beq  $c1eb]
	OP_W_ON_DP_ADDRESS	addq,0x0051,#1       | [$c1e8: inc  $0051]
sub_c1eb:
	OP_1_ON_DP_ADDRESS	tst,0x0052           | [$c1eb: tst  $0052]
	jne	sub_c1f3                           	| [$c1ee: bne  $c1f3]
	GET_ROM_REG_ADDRESS	0x00,d2                	| [$c1f0: lda  $00,x] [rom]
	move.b	(a0),d0                         	| [...]
	addq.w	#1,d2                           	| [$c1f2: inx]
sub_c1f3:
