sub_c005:
sub_c006:
sub_c007:
sub_c008:
sub_boot_c009:                          	| [global]
sub_c009:
	 |  [$c009: lds  #$013f] set stack
	LOG_REGS	c00c,-2   | added by add_reg_log.py
	move.b	#0xff,d0                        	| [$c00c: lda  #$ff]
	LOG_REGS	c00e,-2   | added by add_reg_log.py
