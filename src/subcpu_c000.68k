	LOG_REGS	c025,-2   | added by add_reg_log.py
	GET_DP_ADDRESS	0x65                    	| [$c025: ora  $65]
	or.b	(a0),d0                           	| [...]
	LOG_REGS	c027,-2   | added by add_reg_log.py
	OP_W_ON_DP_ADDRESS	move,0x65,d0         | [$c027: sta  $65]
