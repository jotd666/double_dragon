sub_c02b:
	LOG_REGS	c02b,-2   | added by add_reg_log.py
	rts |  [$c02b: jmp  $c02b] infinite loop, wait for main cpu orders

* triggered when sprites need displaying
sub_irq_c02e:                           	| [global]
sub_c02e:
	LOG_REGS	c02e,-2   | added by add_reg_log.py
	OP_1_ON_DP_ADDRESS	tst,irq_already_called_0066| [$c02e: tst  irq_already_called_0066]
	LOG_REGS	c031,-2   | added by add_reg_log.py
	jne	sub_c036                           	| [$c031: bne  $c036]
* first time IRQ is called it checksums the memory
	LOG_REGS	c033,-2   | added by add_reg_log.py
	jra	rom_checksum_c058                  	| [$c033: jmp  rom_checksum_c058]
sub_c036:
	LOG_REGS	c036,-2   | added by add_reg_log.py
	jbsr	sub_c06c                          	| [$c036: jsr  $c06c]
